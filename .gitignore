# Build artifacts from compiling the Archspace engine
*.o
*.a
*.so
*.lo
*.la

# Compiled binaries
archspace_source/archspace/src/apps/archspace/archspace
archspace_source/archspace/src/apps/archspace/viewsize
archspace_source/archspace/src/apps/relay/relay
archspace_source/archspace/src/apps/battle-sim/battle-sim

# Generated platform Makefile symlinks (created by src/set_platform)
archspace_source/archspace/src/libs/Makefile
archspace_source/archspace/src/libs/*/Makefile
archspace_source/archspace/src/apps/archspace/Makefile
archspace_source/archspace/src/apps/archspace/msg/Makefile
archspace_source/archspace/src/apps/relay/Makefile

# gettext compiled catalogs
*.mo
*.gmo

# Engine runtime log (SLOG/system_log writes "systemlog" in the working dir)
systemlog
archspace_source/archspace/src/apps/battle-sim/systemlog

# Balance-tester generated run outputs (report.md/json, run_state.json)
tools/balance-tester/runs/

# Python (balance-tester orchestrator)
__pycache__/
*.pyc
*.pyo

# Persisted server-side deploy config (written by ec2-bootstrap.sh)
docker/deploy/.deploy.env

# Per-deploy marker (last successfully deployed commit), written on the host
docker/deploy/.last_deployed
