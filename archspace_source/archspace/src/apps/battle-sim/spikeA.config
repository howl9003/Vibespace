# Minimal config for the battle-sim Spike A.
# Paths are relative to apps/battle-sim/ (run the binary from this directory).
# CScript::load() opens these paths verbatim, so we point straight at the .en
# script files (the docker runtime copies them to extensionless names instead).
[Game]
Language = en
TechScript         = ../../script/tech.en
RaceScript         = ../../script/race.en
AdmiralNameScript  = ../../script/admiral_name.en
ProjectScript      = ../../script/project.en
ComponentScript    = ../../script/component.en
ShipScript         = ../../script/ship.en
