msgid ""
"  -M, --message=MESSAGE  Use this commit message instead of the default ones."
msgstr ""
"  -M, --message=MESSAGE  Käytä tätä commit-viestinä normaalin viestin tilalla"

msgid ""
"  -a, --add=FILE        Add this PO file to the compendium. Useful to\n"
"                        include a compendium from a different branch to\n"
"                        the generated compendium."
msgstr ""
"  -a, --add=FILE        Lisää tämä PO-tiedosto kompendiin.\n"
"                        Tätä voi käyttää silloin kun lisäät toisen haaran\n"
"                        kompendin luotuun kompendiin."

msgid ""
"  -b, --base=/PATH  Full path to the (Horde) base directory that should be\n"
"                    used."
msgstr ""
"  -b, --base=/PATH  Polku käytettävään (Horde) perushakemistoon."

msgid ""
"  -c, --compendium=FILE  Merge new translations to this compendium file\n"
"                         instead of the default one (compendium.po in the\n"
"                         horde/po directory."
msgstr ""
"  -c, --compendium=FILE  Yhdistä käännökset tähän kompendiin.\n"
"                         Jos ei haluta käyttää oletustiedostoa \n"
"                         (compendium.po horde/po hakemistossa)."

msgid ""
"  -c, --compendium=FILE  Use this compendium file instead of the default\n"
"                         one (compendium.po in the horde/po directory)."
msgstr ""
"  -c, --compendium=FILE  Käytä tätä kompendia oletuksen sijasta\n"
"                         (compendium.po horde/po hakemistossa)."

msgid "  -d, --debug       Show error messages from the executed binaries."
msgstr "  -d, --debug       Näytä virheilmoitukset käynnistettävistä ohjelmista."

msgid "  -d, --directory=DIR   Create compendium in this directory."
msgstr "  -d, --directory=DIR   Luo kompendi tähän hakemistoon."

msgid "  -h, --help        Show this help message."
msgstr "  -h, --help        Näytä tämä ohje."

msgid "  -l, --locale=ll_CC     Use only this locale."
msgstr "  -l, --locale=ll_CC     Käytä vain tätä lokalisointia."

msgid "  -l, --locale=ll_CC     Use this locale."
msgstr "  -l, --locale=ll_CC     Käytä tätä lokalisointia."

msgid "  -l, --locale=ll_CC    Use this locale."
msgstr "  -l, --locale=ll_CC    Käytä tätä lokalisointia."

msgid "  -m, --module=MODULE    Build MO files only for this (Horde) module."
msgstr "  -m, --module=MODULE    Tee MO-tiedostot vain tälle (Horde) moduulille."

msgid ""
"  -m, --module=MODULE    Commit translations only for this (Horde) module."
msgstr ""
"  -m, --module=MODULE    Commitoi käännökset vain tälle (Horde) moduulille."

msgid "  -m, --module=MODULE    Merge PO files only for this (Horde) module."
msgstr "  -m, --module=MODULE    Yhdistä PO-tiedosto vain tälle (Horde) moduulille."

msgid ""
"  -m, --module=MODULE    Update help files only for this (Horde) module."
msgstr ""
"  -m, --module=MODULE    Päivät ohjetiedostot vain tälle (Horde) moduulille."

msgid "  -m, --module=MODULE    Update only this (Horde) module."
msgstr "  -m, --module=MODULE    Päivitä vain tämä (Horde) moduuli."

msgid "  -m, --module=MODULE   Create a PO file only for this (Horde) module."
msgstr "  -m, --module=MODULE   Luo PO-tiedostot vain tälle (Horde) moduulille."

msgid "  -m, --module=MODULE  Generate POT file only for this (Horde) module."
msgstr "  -m, --module=MODULE  Tee POT-tiedosto vain tälle (Horde) moduulille."

msgid ""
"  -n, --new              This is a new translation, commit also CREDITS,\n"
"                         CHANGES and lang.php.dist."
msgstr ""
"  -n, --new              Tämä on uusi käännös, commitoi myös CREDITS,\n"
"                         CHANGES ja lang.php.dist."

msgid ""
"  -n, --no-compendium    Don't merge new translations to the compendium."
msgstr ""
"  -n, --no-compendium    Älä yhdistä käännöksiä kompendiin."

msgid "  -n, --no-compendium    Don't use a compendium."
msgstr "  -n, --no-compendium    Älä käytä kompendia."

msgid "  -t, --test        Show the executed commands but don't run anything."
msgstr "  -t, --test        Näytä suoritettavat ohjelmat, mutta älä aja niitä."

msgid "  commit      Commit translations to the CVS server."
msgstr "  commit      Kommitoi käännökset CVS-palvelimelle."

msgid "  commit-help Commit help files to the CVS server."
msgstr "  commit-help Kommitoi ohjetiedostot CVS-palvelimelle."

msgid ""
"  compendium  Rebuild the compendium file. Warning: This overwrites the\n"
"              current compendium."
msgstr ""
"  compendium  Tee kompendi uudestaan. Varoitus: Tämä kirjoittaa\n"
"              uuden kompendin vanhan päälle."

msgid "  extract     Generate PO template (.pot) files."
msgstr "  extract     Tee PO-kaavatiedosto (.pot)."

msgid "  help        Show this help message."
msgstr "  help        Näytä tämä ohje."

msgid ""
"  init        Create one or more PO files for a new locale. Warning: This\n"
"              overwrites the existing PO files of this locale."
msgstr ""
"  init        Luo yksi tai useampi PO-tiedosto uudelle lokalisoinnille.\n"
"              Varoitus: Tämä kirjoittaa lokalisoinnin uuden PO-tiedoston\n"
"              vanhan päälle"

msgid "  make        Build binary MO files from the specified PO files."
msgstr "  make        Tee binäärinen MO-tiedosto PO-tiedostoista."

msgid ""
"  make-help   Mark all entries in the XML help file being up-to-date and\n"
"              prepare the file for the next execution of update-help. You\n"
"              should only run make-help AFTER update-help and revising the\n"
"              help file."
msgstr ""
"  make-help   Merkitse kaikki osiot XML-muotoisesta ohjetiedostosta \n"
"              päivitetyksi ja valmistele tiedosto update-help komennon\n"
"              ajoa varten. Sinun pitää ajaa make-help sen jälkeen kun olet\n"
"              päivittänyt ohjetiedostoa ja ajanut update-help komennon."

msgid ""
"  merge       Merge the current PO file with the current PO template file."
msgstr ""
"  merge       Yhdistä nykyinen PO-tiedosto ja PO-kaavatiedosto."

msgid "  update      Run extract and merge sequent."
msgstr "  update      Aja extract ja merge yhdistelmä."

msgid ""
"  update-help Extract all new and changed entries from the English XML help\n"
"              file and merge them with the existing ones."
msgstr ""
"  update-help Hae kaikki uudet ja päivitetyt osiot englanninkielisesta\n"
"              XML-muotoisesta ohjetiedostosta ja yhdistä ne olemassaolevien\n"
"              osioiden kanssa."

