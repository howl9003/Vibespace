INSERT INTO posts VALUES (1376,615,28,285,'РчЦэМКРК ИИЕщОюСЎ РжДТ ЧдДыПЁМ­ ЛчЗЩАќРЛ БГУМ\r<BR>ЧЯАХГЊ, ЧдМБРЧ СОЗљИІ БГУМЧв МіЕЕ РжАэ, ЧдМБ\r<BR>МіИІ ДУИЎАХГЊ ЛЌ Мі РжНРДЯДй. ЧЯСіИИ БзЗВ ЖЇ\r<BR>ИЖДй АцЧшФЁАЁ СЖБнОП ЖГОюС§ДЯДй.\r<BR>ХНЛчДТ ЛѕЗЮПю ЧрМКРЛ УЃРЛ ЖЇ ЛчПыЧЯДТ СпПфЧб\r<BR>ИоДКРдДЯДй. АХРЧ ЧЯЗчСОРЯ АЩИЎДТ АцПьАЁ ИЙСі\r<BR>ИИ РиСіИЛАэ ЧрМКРЛ УЃОЦМ­ КИРЏЧрМК М§РкИІ ДУ\r<BR>ИЎЕЕЗЯ ЧеДЯДй. СпПфЧеДЯДй!!!!!!!!!!!!!!!!!!!\r<BR>РгЙЋДТ ШЦЗУ,ЧрМКСжЕа,МјТћ,ЕПИЭЦФАпРЬ РжНРДЯ\r<BR>Дй. ШЦЗУРК ГВДТ ЧдДыИІ СжЗЮ ЧЯЕЕЗЯ ЧЯБц ЙйЖј\r<BR>ДЯДй. 2НУАЃ ЕПОШ ЙцОюПЁ ТќАЁЧв Мі ОјСіИИ ШЦ\r<BR>ЗУЕШ ЧдДыАЁ ШЦЗУЕЧСі ОЪРК ЧдДыКИДй ГДДйДТ АЭ\r<BR>РК ГЪЙЋЕЕ ДчПЌЧб ИЛРЬСв. ЧрМКСжЕаРК УжМвЧб\r<BR>Чб ЧрМКПЁ ЧЯГЊРЧ ЧдДыДТ СжЕаНУХАЕЕЗЯ ЧеНУДй.\r<BR>БзЗИДйАэ Бз ЧдДыИИ СжЕаНУХАСіДТ ИЖНУАэ ЙјАЅ\r<BR>ОЦАЁИщМ­ ШЦЗУРЛ ЧЯЕЕЗЯ ЧеДЯДй. МјТћРК 8НУАЃ\r<BR>ЕПОШ Бз ЧрМКПЁ ИгЙАИщМ­ СжЕаЧдДыПЭ ЖШААРК\r<BR>ЙцОюИІ ИУАд ЕЫДЯДй. ЕПИЭЦФАпРК ЕПИЭРЛ ИЮРК\r<BR>ЧрМКРИЗЮ ЧдДыИІ КИГЛДТ АЭРдДЯДй. НчДй ЖЇЙЎРЮ\r<BR>Сі ЕПИЭРЬ БњОюСіДТ ЙйЖїПЁ ДйНУ МвШЏЧЯБф ЧпСі\r<BR>ИИ ОюТЗЕч РњПЭ ЕПИЭРЛ ИЮРИНУДТ КаЕщПЁАдДТ Рћ\r<BR>СіИИ ЙнЕхНУ ЕПИЭЦФАпРЬ ГЊАЉДЯДй. ^^;\r<BR>МвШЏРК РгЙЋИІ ИУРК ЧдДыИІ ДыБт ЛѓХТЗЮ ИИЕхДТ\r<BR>АЭРдДЯДй. ХНЛчИІ ГЊАЃ ЧдДыДТ МеРЛ ДыСі ИЖНУАэ\r<BR>ЧрМКСжЕа ЧдДыИІ БГУМЧв ЖЇ РЬПыЧЯЕЕЗЯ ЧЯММПф.\r<BR>ЧиЛъРК ИЛ БзДыЗЮ ТѕОюСіДТ АЬДЯДй.^^;\r<BR>ЧдДыПЁ АќЧб АЭЕЕ ИЙРК РкЗсАЁ ЧЪПфЧбЕЅ ОЦСї\r<BR>УЪБтЖѓ ЙіБз ЖЇЙЎРЮСі... ИИЕщОюГѕРК ЧдМБРЬ Йй\r<BR>ВюАХГЊ ОЦПЙ ЛчЖѓСіДТ АцПьАЁ ИЙНРДЯДй. ОЦДЯИщ\r<BR>ДЉБКАЁПЁАд АјАнРЛ ЙоОЦМ­ БзЗВ МіЕЕ РжАкСіИИ..\r<BR>ОЦСї КвШЎНЧЧб АЭРЬ ГЪЙЋ ИЙНРДЯДй. \r<BR>БзЗЁЕЕ ЦїБтЧЯСі ИЖНУАэ П­НЩШї ЧЯММПф~!!!','2002-04-05 13:55','211.202.189.213','НКХИРЬГЪ');
