INSERT INTO posts VALUES (2263,1033,190,2017,'ЗЙКЇ5\r<BR>АјАнМгЕЕ 250 СжЛчРЇ БМИВ 15 \r<BR>СжЛчРЇ ХИРд 17 ГУАЂ НУАЃ 375 \r<BR>ЙпЛчАЂ 180 ЙЋБт МгЕЕ 50 \r<BR>АјАнЙќРЇ 1500 АјАЃ 50\r<BR>....РЬПЭ ААРК МіФЁАЁ РжДТЕЅ..\r<BR>РЬАд ИгЖѓДТ МвИЎРЮСі? ЄбЄб^\r<BR>\r<BR>АјАнМгЕЕДТ ЧбЙпНюАэ ЖЧ НђЖЇ МгЕЕРЮСі? ОЦДЯИщ МБАјЧвМі РжДТ МгЕЕРЮСі?\r<BR>\r<BR>СжЛчРЇ БМИВРЬЖћ СжЛчРЇ ХИРдРК ЦФБЋЗТПЁ АќЧбАЭ ААРКЕЅ ОюЖВ ТїРЬРЮСі?\r<BR>\r<BR>АјАнМгЕЕАЁ РжДТЕЅ ГУАЂНУАЃРК ЖЧ ЙКСі?\r<BR>\r<BR>ЙпЛчАЂРК СТПь ИюЕЕБюСі АЁДЩЧб ЙЋБтЖѓДТАЭРЬЖѓДТАЧ ОЫАкАэ..\r<BR>\r<BR>АјАнМгЕЕЖћ ЙЋБтМгЕЕЖћ ЙЋНМТїРЬРЮСі??\r<BR>\r<BR>АјАнЙќРЇДТ ЛчСЄАХИЎИІ ИЛЧЯДТАЭ ААРКЕЅ??\r<BR>\r<BR>АјАЃРК ЖЧ ЙЋОљРЛ ИЛЧЯДТАЧСі?\r<BR>\r<BR>ЗЙКЇРК БзГЩ РЬ ЙЋБтАЁ ЗЙКЇ 5БоРЬЖѓДТ АЧСі? ОЦДд ЗЙКЇПЁ ЦлМОЦЎАЁ АЁСпЕЩМі РжДТАЧСі?\r<BR>\r<BR>--------------------------------------------\r<BR>\r<BR>ЗЙКЇ 5 \r<BR>ЙцОю МгЕЕ 50 HP АЁСпФЁ 3.40 \r<BR>ШПАњ Repair +1% for each 2 turn\r<BR>PSI Defense +50%\r<BR>Projectile Defense -20%\r<BR>\r<BR>.......\r<BR>\r<BR>ЗЙКЇПЁ АќЧбАЧ ЙЋБт СњЙЎЛчЧзАњ АААэ..\r<BR>\r<BR>ЙцОюМгЕЕАЁ ЙцОюЗТРЬЖѓДТАЭ ААРКЕЅ? ОюЖВ РЧЙЬ РЮСі?\r<BR>\r<BR>HP АЁСпФЁДТ ЧдМБ БтКЛ HPАЁ ЕћЗЮ СИРчЧЯАэ Бз ЧдМБ БтКЛ HPПЁ %ЗЮ ДѕЧиСіДТАЧСі ОЦДд? БзГЩ + ЗЮ ДѕЧиСіДТАЧСі?? ОЦДд ЙнДыЗЮ - АЁ ЄбЄб?\r<BR>\r<BR>БзИЎАэ ШПАњПЁ ДыЧи ОЦХЉИоРЬСі УГЗГ ЕћЗЮ ЧЅИІ ИИЕщОю МГИэРЛ ЧиСжНЩРЬ ОюЖВСі?\r<BR>\r<BR>ПЕРкДд ЧЯГЊЧЯГЊ МГИэЧиСжНУБт ЙйЖјДЯДй. ОЦДЯИщ ЙщАњЛчРќПЁ КЮАЁМГИэРЛ УпАЁЧЯДТ ЙцЙ§РК ОюЖАНХСі?\r<BR>\r<BR>IP: Logged\r<BR> \r<BR>Mondein\r<BR>ЙЬЕюЗЯРк   posted 04-06-2002 12:25 PM             \r<BR>--------------------------------------------------------------------------------\r<BR>HPУпАЁДТ ЦлМОЦЎАЁ ИТДйАэ ОЫАэ РжНРДЯДй.\r<BR>\r<BR>БзИЎАэ СжЛчРЇДТ СжЛчРЇ БМИВРК ИюЙј БМИЎДРГФ..\r<BR>ХИРдРК СжЛчРЇАЁ ИюИщУМДРГФ...ЖѓДТ АХСв.\r<BR>\r<BR>ПЙИІЕщОю БМИВРЬ 12, ХИРдРЬ 6РЬЖѓИщ\r<BR>УжМв 12*1\r<BR>УжДы 12*6\r<BR>\r<BR>12~72 БюСіРЧ ЕЅЙЬСіАЁ ГЊПТДйАэ КИИщ ЕЧАкСв.\r<BR>\r<BR>6ИщУМ 12ЙјРЬДЯ 1РЬ ГЊПЭЕЕ УжМв 12АкАэ..\r<BR>РпГЊПРИщ...ПШ -_=;\r<BR>\r<BR>\r<BR>БзИЎАэ ГУАЂМгЕЕДТ ЙЋБт ЙпЛчШФ ЕєЗЙРЬ..РЯАЬДЯДй.\r<BR>ГУАЂМгЕЕАЁ ТЊРКАд Дѕ ПЌЛчАЁ КќИІХзБИПф.\r<BR>\r<BR>\r<BR>БзИЎАэ ПЁЖЧ...АјАЃРК ТїСіЧЯДТ АјАЃРдДЯДй.\r<BR>\r<BR>\r<BR>ЧдМБПЁ ННЗд(ЙЋБтННЗд) РЬ РжДТАЭ ОЫСв?\r<BR>БзЗБЕЅ БзАЭ ПмПЁЕЕ &quot;ННЗдДч АјАЃ(ПЉЙщРЬДјАЁ?)&quot; РЬЖѓДТ ЧзРЬ РжСв.\r<BR>(ННЗд/АјАЃ)\r<BR>\r<BR>ПЙИІ ЕщОюКИЕЕЗЯ ЧЯСв. \r<BR>\r<BR>ФнКЊАњ ЧСИЎБъРК ННЗдРЬ 2АГЗЮ ААНРДЯДй.\r<BR>ФкИЃКЊРК ННЗдДч АјАЃРЬ 88РдДЯДй.\r<BR>ЧЯСіИИ ЧСИЎБъРК 153 РдДЯДй. \r<BR>ФнКЊПЃ ЧУЖѓСюИЖКіРЬ 3ЙЎ ДоИЎСіИИ ЧСИЎБъПЃ 5ЙЎ ДоИЎСв.\r<BR>ЧУЖѓСюИЖКіРЧ АјАЃРК 28РдДЯДй.\r<BR>\r<BR>\r<BR>Ся, АјАЃРЬЖѕ &quot;Бз ЙЋБт ЧбЙЎ(кІ)РЬ ТїСіЧЯДТ ЧдМБГЛРЧ РкИЎ&quot; АЁ ЕЧДТ МРРЬАкСв?\r<BR>\r<BR>БзПмПЃ ЕЕРњШї ГЪЙЋ ЧђАЅЗСМ­ Єб,.Єб\r<BR>\r<BR>УпУјИИ ЧЯАкНРДЯДй.\r<BR>\r<BR>АјАн МгЕЕДТ РќУМРћРЮ КёБГИІ ЧиКУРЛЖЇ\r<BR>АјАнРЛ АГНУЧЯДТ ЙЮУИЕЕ РЮЕэ ЧеДЯДй.\r<BR>\r<BR>ЧбЦэ ЙЋБтМгЕЕДТ ЙЋБтАЁ ГЏОЦАЁДТ МгЕЕРЮЕэ ЧеДЯДй.\r<BR>(КіЗљАЁ 1000РИЗЮ УжА­, ХКЕЕАЁ 200Ты, ЙЬЛчРЯЗљАЁ 50РЬСв.)\r<BR>\r<BR>Ся ЙЬЛчРЯАњ КіРЬ ЛчАХИЎАЁ ААДйИщ КіРЬ ИеРњ ИТДТДй...ЖѓДТ ОъБтАЁ ЕЧАкСв. ....ЙАЗа ЙЬЛчРЯРЬ ШЮОР БцСіИИ.(КіРЬ УжАэРЮ РКПЕРќАњДТ ЦВИЎДй!)\r<BR>\r<BR>[КЛ АдНУЙАРК Mondein ДдРЬ 04-06-2002 ПЁ МіСЄЧЯПДНРДЯДй]\r<BR>\r<BR>[КЛ АдНУЙАРК Mondein ДдРЬ 04-06-2002 ПЁ МіСЄЧЯПДНРДЯДй]\r<BR>\r<BR> \r<BR>','2002-04-07 23:31','211.203.222.154','ИѓЕЅРЮ');
