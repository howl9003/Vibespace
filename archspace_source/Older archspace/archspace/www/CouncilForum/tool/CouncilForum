INSERT INTO posts VALUES (611,293,201,0,'ОюЖВСЁРЬ БУБнЧбСі НсСжММПф ^^;\r<BR>РН..ДыУц РЇПЁМ­КЮХЭ МГИэЧЯИщ\r<BR>ГЛСЄИоДКИІ ХЌИЏЧЯИщ ДыЗЋРћРЮ БЙАЁЛѓШВРЬ\r<BR>ГЊПЩДЯДй. ГЛСЄОеПЁ +ИІ ХЌИЏЧЯИщ РлРК\r<BR>ФЋХзАэИЎЕщРЬ ГЊПРДТЕЅ АцСІСЄУЅРК\r<BR>\'БеЧќ\',\'АјОї\',\'ПЌБИ\',\'БКЛч\' ГзАЁСіАЁРжДТЕЅ\r<BR>ИЛБзДыЗЮСв..АјОїРК ppМіРдРЛ ДУЗССжДТАХАэ\r<BR>ПЌБИДТ ПЌБИМгЕЕИІ КќИЃАдЧиСжДТАЭРЬИч\r<BR>БКЛчДТ ЧдМБАЧСЖМгЕЕИІ ДУЗССжДТАХАкСв ^^\r<BR>УЪЙнПЁДТ \'ПЌБИ\'И№ЕхАЁ АЁРх ССРКАХААГзПЉ\r<BR>\'ЧрМК АќИЎ\'ИІ ДЉИЃИщ МвРЏЧб ЧрМКЕщРЬ ГЊПРДТЕЅ\r<BR>ЧрМКЕщРЬ СжПэ ГЊПРДТЛѓХТПЁМ­ ЧрМКРЬИЇРЛ\r<BR>ХЌИЏЧЯИщ Бз ЧрМКРЧ ЛѓШВРЬ ГЊПРСв\r<BR>РЏСіКёЖѓДјСі Л§ЛъppЖѓДјСі ЧЯДТАЭЕщРЬПф\r<BR>ЙиТЪПЁ КИИщ ХѕРкОз РЬЖѓАэ ГЊПРДТЕЅ\r<BR>ПЉБтПЁ ХѕРкЧЯИщ РЮБИЧбАшФЁКИДй СЛДѕ РЮБИИІ\r<BR>ДУЗССжИщМ­ ЖЧЧб РкНХАњ ДйИЅ ШЏАцРЧ ЧрМКРЧ\r<BR>АцПьПЁДТ РкНХРЧ ШЏАцПЁ ИТУч СЁТїАГМБЕЧАдЧи\r<BR>СнДЯДй. ХѕРкИІ ОШЧиЕЕ ШЏАцРК СЁТї АГМБРЬЕЧГЊ\r<BR>ЧиСжИщ Бз МгЕЕАЁ СЛ ЛЁЖѓСіСв.\r<BR>ДйРН \'ПЌБИ\'ЧзИёРЛ ДЉИЃИщ ХѕРкОзРЬ ГЊПРАэ\r<BR>ПЌБИСпРЮ БтМњРЬЖѓДТАд ГЊПЩДЯДй.\r<BR>ХѕРкОзПЁ ppИІ ХѕРкЧЯИщ ПЌБИ СОСЗСіЧЅАЁ\r<BR>СѕАЁЧЯИщМ­ Бз ХѕРкОзРЛ ОЕЕПОШ ПЌБИМгЕЕАЁ\r<BR>СЛДѕ ЛЁЖѓСіАд ЕЧСв. ПЌБИСпРЮ БтМњРК УЗПЁДТ\r<BR>РкРЏПЌБИЗЮ ЕЧРжРЛАЧЕЅ Бз ЛѓХТЗЮ ГРЕЮДТАд\r<BR>ССНРДЯДй. ЕћЗЮ ЧЯАэНЭРК ПЌБИИІТяОюМ­ ЧвМіЕЕ\r<BR>РжДТЕЅ Бз АцПьПЃ ppМвИ№АЁ ФПМ­ СЛ ДРИЎСв.\r<BR>\'ЧСЗЮСЇЦЎ\'ЖѕРЧ АцПь УЗПЁДТ ОЦИЖ Д­ЗЏЕЕ\r<BR>БИРдЧвМіРжДТ ЧСЗЮСЇЦЎАЁ ОјДйАэ ГЊПРАкСіИИ\r<BR>ПЌБИИІ ЧиГЊАЁДйКИИщ ОюЖВ ПЌБИИІ ЧЯИщ БзПЁ\r<BR>ЕћИЅ ЧСЗЮСЇЦЎАЁ ГЊПРДТАд РжСв. БзЖЇДТ\r<BR>ЧСЗЮСЇЦЎИІ БИРдЧвМіАЁРжНРДЯДй.\r<BR>\r<BR>ПмБГЖѕААРКАцПьДТ..Иг ДыУц Дй ОЦНЧАЭАААэ..\r<BR>СІБЙПмБГЕЕ ГбОюАЁАэ..\r<BR>\r<BR>\'ЧдДы\'ИІ ЧбЙј КИИщ,\r<BR>ЧдДыПЗПЁ +ИІ ХЌИЏЧЯИщ РлРК ИоДКЕщРЬ ТпГЊПЩДЯДй.\'ЧдМБМГАш\'ДТ ОЦНКИІ ЧЯДТКаЕщРЬЖѓИщ Тќ ФЃМїЧб ДмОюРЬАэ \'ЧдМБАЧСЖ\'ИІ ДЉИЃНУИщ ХѕРкЖѕПЁ\r<BR>ppИІ ХѕРкЧЯНУИщ ИЖТљАЁСіЗЮ ЧдМБАЧСЖМгЕЕАЁ\r<BR>ОрАЃ КќИЃСв. \'ЧдДыЛчЗЩАќ\'ЖѕРЛ КИРкИщ\r<BR>Д­ЗЏКИНУИщ ЙшМгЕШ ЧдДыЛчЗЩАќАњ ЙпЗЩЕЧСіОЪРК СІЕЖЕщРЬ ГЊПРСв АЂАЂРЧ РЬИЇРЛ Д­ЗЏКИНУИщ\r<BR>Бз ЛчЗЩАќРЧ ДЩЗТФЁИІ КММіРжДТЕЅ ВПИЎДйНЭРКАЧ\r<BR>ТЉЖѓЙіИЎНЪНУПф. Еќ КИИщ ЛчЗЩАќРЬИЇПЗПЁ ЗЙКЇАњ АцЧшФЁАЁ ГЊПРАэ ЧдДыИэЗЩРЬЖѓДТ ДЩЗТРЬРжДТЕЅ РЬАЧ Бз СіШжАќРЬ УжДыЗЮ СіШжЧвМіРжДТ ЧдМБРЧ СІЧбМіРдДЯДй. ЗЙКЇРЬ ПРИЃИщ РкПЌНКЗДАд ЛѓНТЧЯДТ ДЩЗТРЬСіПф.\'ЕЕХЉ\'ЖѕПЁДТ РќРяЧЯДй ЛЧАГСјЧдМБРЧ МіИЎЛѓШВРЬГЊ АЧСЖЧиМ­ ГЊПТ ЧдМБРЧ ДыБтЛѓХТИІ КИНЧМіРжАэПф \'НХЧдДыЦэМК\'РК ЛѕЗЮ ЧдМБРЛ АЧСЖЧпРЛЖЇ ЛѕЗЮПю ЧдДыИІ ИИЕхДТАХСв.\r<BR>\'РчЦэМК\'РК БтСИРЧ ЧдДыПЁ ЖШААРК ХИРйРЧ ЧдМБРЛ УпАЁЧЯНЧЖЇ ЧЪПфЧбБтДЩРЬАэ..\r<BR>\'ХНЛч\'ИэЗЩРК УЗКЮХЭ РЏПыЧб ДЩЗТРЮЕЅ ЛѕЗЮПюЧрМКРЛ ЙпАпЧиОпЧЯДЯ ВйСиШї КИГЛДТАЭРЬ ССНРДЯДй.\r<BR>\'РгЙЋ\'ДТ..КА ЧЪПфОјРЛАЭАААэ..\'МвШЏ\'РК ХНЛчГЊ РгЙЋИІ МіЧрСпРЮ СіШжАќРЛ КвЗЏЕщРЬДТАЭРЬАэПф\'ЧиЛъ\'РК ЧдДыЧиУМСв.\r<BR>\r<BR>\'РќРя\'ПЗПЁ +ИІ ДЉИЃИщ ПЉЗЏИоДКАЁ ГЊПРДТЕЅ\r<BR>\'АјМКРќ\'ААРКАцПь ЛѓДыЙцРЧ ЧрМКРЛ ЛЏОюПРДТАХАэ \'НРАн\'РК ЦјАнЧиМ­ ЛѓДыЙцЧрМКРЧ РЮБИИІ ОјОжДТАЭРЬСв. \'ЛчЗЋ\'РК ОрХЛРЮЕЅ ЛѓДыЙц ppАХРЧ АЁСЎПРСіЕЕ ИјЧЯДТ..КАЗЮ ОЕИ№ОјДТБтДЩАААэПф.\r<BR>\'ЙцОюАшШЙ\'ДЉИЃМХМ­ РЯЙнЙцОюАшШЙРЛ ДЉИЃАэ\r<BR>ЧдДыИІ ЙшФЁЧЯНУИщ(ПЉБтМ­ РЯЙнЙцОюАшШЙ ЙйЗЮ ПРИЅТЪПЁ NEW/CHANGE ЖѕРЛ ДЉИЃНУИщ ЙшФЁЧв ЧдДыИІ МБХУЧвМіРжНРДЯДй. АэИЃНУАэ БтЧдРЛ МБХУЧЯНУАэ okИІ ДЉИЃНУИщ СіЕЕААРКАд ГЊПРАэ АЁПюЕЅПЃ\r<BR>ЛЁАЃСЁРЬ РжСв. СіЕЕРЧ ПРИЅТЪ ЛѓДмТЪПЁДТ\r<BR>ЦФЖѕММИ№ЕщРЬ КИРЬДТЕЅ БзАЩ ХЌИЏЧЯНУАэ ЕхЗЁБзЧиПЭМ­ СјЧќРЛ ТЉМіРжДТАЬДЯДй. РЬАЧ РќРяНУПЁЕЕ ЧдДыСјЧќРЛ ТЅДТПфЗЩАњ ЖШААНРДЯДй.) ЙцОюАшШЙРЬ МіИГЕЧДТАХСв.\r<BR>\'РќХѕКИАэМ­\'ДТ..Иг РќРяБтЗЯАЫЛіРЬАэ..\r<BR>\r<BR>ДйРН ЙиПЁ ИоДКЕщРК..БзДйСі МГИэЧвАЧ ОјДТАЭААГзПЉ. ЧуСЂЧб МГИэРЬАэ ЦВИАКЮКаЕЕ РжРЛСі И№ИЃСіИИ ГЊИЇДыЗЮ НсКЛАЬДЯДй ЕЕПђРЬ ЕЧНУБтИІ ^^;\r<BR>\r<BR>','2002-04-04 15:29','210.178.135.254','ШЏХИ');
