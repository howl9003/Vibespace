INSERT INTO posts VALUES (1451,649,178,0,'ЕЕПђРЬ ЕЧНЧЗБСу.... \r<BR>\r<BR>1. СОСЗ\r<BR>\r<BR>- ОЦХЉНКЦфРЬНКРЬ АЂ СОСЗРК АњЧа/БтМњ/БКЛчЕю РќЙнПЁ АЩУФМ­ АЂАЂРЧ ПьП­МКРЛ АЁСјДй. ЦЏКАШї \r<BR>\r<BR>А­ЧбСОСЗРЛ ВХРЛМіДТ ОјРИГЊ АГРЮРЧ УыЧтПЁ ЕћЖѓ УыЛчМБХУЧЯДТ АЭРЬ ССРН. СОСЗРК М­ЙіАЁ ИЎМТ\r<BR>\r<BR>ЕЩЖЇИИ ЙйВмМі РжРИИч РЧЕЕРћРИЗЮ ФГИЏХЭИІ СзАдЧЯДѕЖѓЕЕ ЙйЗЮ АдРгРЛ ДйНУНУРлЧЯАд ЕЧИщ ПЙРќРЧ \r<BR>\r<BR>СОСЗРЛ БзДыЗЮ АЁСіАдЕЪ. БзЗВЖЇДТ ПьМБ АдРгРЛ СОЗсЧбШФ РчЕюЗЯРЛ ЧиОпЧд.\r<BR>\r<BR> \r<BR>\r<BR>2. ЧрМК\r<BR>\r<BR>- ОЦХЉНКЦфРЬНКДТ ЧрМКРЛ ДУЗСАЁИч БЙЗТРЛ НХРхНУХАДТ АзРЬДй. ЕћЖѓМ­ ЧрМКРК ИХПьСпПфЧЯДй. \r<BR>\r<BR>ЧрМКРК И№ЕЮ И№ЧрМК ЧЯГЊЗЮ НУРлЧбДй. ЧбЙј ОђАдЕШ ЧрМКРК ЦїБтЧвМі ОјДй. БзЗЏЙЧЗЮ ЧрМКМБХУАњ\r<BR>\r<BR>АќИЎДТ ИХПь НХСпЧиОп ЧбДй. ЧрМКРЛ ДУИЎДТ ЙцЙ§РК ЧдДыИІ ХНЛчКИГЛМ­ ОђРЛМі РжАэ ДйИЅ ЧУЗЙРЬ\r<BR>\r<BR>ОюРЧ ЧрМКРЛ АјЗЋЧиМ­ ХЛУыЧвМі РжДй. ХНЛчЙцЙ§РК КёБГРћ НБАд ЧрМКРЛ ОђРЛМі РжДйДТ РхСЁРЬ Рж\r<BR>\r<BR>СіИИ, ДыКЮКа БиЕЕЗЮ П­ОЧЧб ЧрМКРЛ УыЧЯБтПЁ ЧрМКРЛ ЙпРќНУХАБтРЇЧи ЙЋУД АэЛ§РЛ ЧиОпЧбДй. Рќ\r<BR>\r<BR>ХѕИІ ХыЧб ХЛУыРЧ ЙцЙ§РК ПьМіЧб ЧрМКРЛ ОђРЛМі РжСіИИ, РкФЉ ЧЧЙйЖїРЛ ИєАэ ПУМі РжДйДТ ДмСЁРЬ \r<BR>\r<BR>РжДй. ЧрМКРЛ ОђРЛМі РжДТ СІ3РЧ ЙцЙ§РК ОЯНУРхПЁМ­ СІБЙРЬ РгДыЧи ГѕРК ЧрМКРЛ БИРдЧЯДТ АЭРЬДй. \r<BR>\r<BR>ОЦСж ССРК ЧрМКРЛ БИЧвМі РжРИГЊ КёПыРЬ Гб ИЙРЬ ЕчДй.\r<BR>РЯДм ОђАдЕШ ЧрМКРЧ ШЏАцРЬ ФшРћЧв АцПьПЃ БЛРЬ PPИІ ХѕРдЧв ЧЪПфАЁ ОјДй. ЧЯСіИИ П­ОЧЧЯАХГЊ Ль\r<BR>\r<BR>РЮРћРЮ ЧрМКРЛ ОђАдЕЧИщ БзАїПЁ PPИІ ХѕРдЧиМ­ ШЏАцРЛ АГМБНУФбОпЧбДй. АЁСіАэ РжДТ ЧрМКРК ХЯДч\r<BR>\r<BR>РкЕПРћРИЗЮ АЧЙАРЬ ММПіСіАэ ЕЗЕЕ ЕщОюПТДй. ЧуГЊ, РкПјРЬ БиКѓРЮ АїПЁДТ АјРхКИДйДТ ПЌБИМвПЭ БК\r<BR>\r<BR>ЛчБтСіИІ АЧМГЧЯДТ АЭРЬ Дѕ ШПРВРћРЬДй. РкПјРЬ КИХыРЬЛѓРЮАїПЁ АјРхРЛ С§СпРћРИЗЮ АЧМГЧиСжИщ \r<BR>\r<BR>РчСЄОЧШ­ДТ РЯОюГЊСі ОЪДТДй. ЧрМКРЧ ШЏАцАГМБКёПыРК ИюНЪИИPPСЄЕЕАЁ ССДй. PPИІ ИЙРЬ ХѕРдЧв\r<BR>\r<BR>МіЗЯ ШЏАцАГМБЕЧДТ ДмАшДТ ДѕПэ ДмУрЕШДй.\r<BR>ЧрМКПЁ СіРК АЧЙАРК ЦФБЋАЁ КвАЁДЩЧдРИЗЮ УГРНКЮХЭ АЧМГКёРВПЁ НХАцРЛ НсОпЧбДй. \r<BR>\r<BR>\r<BR>3. PP(Production Point)\r<BR>\r<BR>- ОЦХЉНКЦфРЬНКПЁМ­ ЕЗАњ ААРК АГГфРИЗЮ ЛчПыЕЧДТ АЭРИЗЮ PPАЁ ИЙРЛМіЗЯ Дѕ ИЙРК ШАЕПРЛ ЧвМі Рж\r<BR>\r<BR>Дй. АХРЧ И№Еч АЭРЬ PPИІ ПфБИЧЯБт ЖЇЙЎРЬДй.\r<BR>PPМіРдРЛ ДУИЎЗСИщ РЮБИИІ ДУЗСОпЧЯАэ АјРхМіАЁ ИЙОЦОп ЧЯИч, АцСІСЄУЅРЛ АјОїРИЗЮ МГСЄЧЯДТ АЭ\r<BR>\r<BR>РЬ ССДй. БтКЛРћРИЗЮДТ ЧрМКРЬ ДУОюГЊОп ЧбДй.\r<BR>\r<BR> \r<BR>\r<BR>4. ПЌБИ\r<BR>\r<BR>- ОЦХЉНКЦфРЬНКДТ ПЌБИРЧ КёСпРК ИХПьГєАэ, СпПфЧЯДй. ПЌБИДТ ХЉАд 4АЁСі ЧзИёРИЗЮ ГЊДЕОюСЎ РжДй.\r<BR>\r<BR>ЛчШИАњЧаКаОпДТ ЦђРЧШИ ГЛ/ПмРЧ ПмБГПЁ ХЋЕЕПђРЛ СиДй. Л§ИэАњЧаРЧ ЙпДоРК ЧрМКРЧ ШЏАцАњ СОСЗРЧ \r<BR>\r<BR>МКРхПЁ ПЕЧтРЛ ЙЬФЁАэ, ЙАСњ-ПЁГЪСіАњЧаРК РќХѕИІ МіЧрЧЯДТ ЧдМБРЧ ЕПУМПЭ ЙЋБт БзИЎАэ АЂСО МГКё\r<BR>\r<BR>ПЁ СїСЂРћРЮ ПЕЧтРЛ ЙЬФЁИч, СЄКИАњЧаРК РќЙнРћРЮ ПЌБИМгЕЕРЧ ЧтЛѓРЛ АЁСЎПТДй. РЬ ГзАЁСіДТ И№ЕЮ \r<BR>\r<BR>СпПф ЧЯСіИИ ОюДРЧб КаОпИИ С§СпРћРИЗЮ ЧтЛѓНУХАЗСИщ ИёРћСіЧт ПЌБИИІ НУФбОпЧЯАэ БзЗВ ЧЪПфАЁ Ој\r<BR>\r<BR>ДйАэ ЧвАцПьПЃ РкРЏПЌБИЗЮ МГСЄЧиГѕОЦОп ЧбДй.\r<BR>\r<BR> \r<BR>\r<BR>5. ЦђРЧШИ\r<BR>\r<BR>- ОЦХЉНКЦфРЬНКДТ СІБЙРЧ СіЙшЧЯПЁМ­ ЦђРЧШИИІ СЖСїЧЯПЉ ШАЕПЧдРИЗЮ АЂАЂРЧ ЧУЗЙРЬОюРЧ ШПАњИІ Би\r<BR>\r<BR>ДыШ­ЧвМі РжДй. ЦђРЧШИРЧРхРК ЛчШИАњЧаКаОпИІ ИЖНКХЭЧЯПЉ ЕЖИГРЛ МБО№ЧдРИЗЮ ОђРЛМі РжАэ, ОЦДЯИщ \r<BR>\r<BR>ЦђРЧПјЕщРЧ ХѕЧЅСп ИЙРК СіСіИІ ИЙРК ЛчЖїРЬ ЦђРЧШИРЧРхРЬ ЕЩМі РжДй. ЦђРЧШИРЧРхРК ЦђРЧШИРЧ И№Еч \r<BR>\r<BR>ЛѓШВРЛ АсСЄЧвМі РжАэ, ЦђРЧПјЕщРЛ ЙоОЦЕщРЯМі РжДТБЧЧбРЬ РжДй. ЦђРЧШИ БнАэПЁ БтКЮЕШ PPИІ ЛчПы\r<BR>\r<BR>ЧЯПЉ ЦђРЧШИ ЧСЗЮСЇЦЎИІ БИРдЧвМі РжРИИч РЬ ЧСЗЮСЇЦЎДТ ЦђРЧШИГЛРЧ И№Еч ЧУЗЙРЬОюПЁАд ПЕЧтРЛ ГЂ\r<BR>\r<BR>ФЅМіАЁ РжДй. ЦђРЧШИАЃРЧ РќХѕЕЕ АЁДЩЧЯДй.\r<BR>\r<BR>','2002-04-05 17:19','211.208.193.101','гољг№ЈЯа');
