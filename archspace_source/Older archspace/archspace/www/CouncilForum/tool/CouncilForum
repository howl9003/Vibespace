INSERT INTO posts VALUES (174,120,101,1080,'ОШГчЧЯММПф?\r<BR>ПьИЎ ЦђРЧШИ АГМГРкРЮ ФЩЛчИЃЖѓАэ ЧеДЯДй.\r<BR>\r<BR>ЧіРч РњРЧ БЙЗТРЬ ПьИЎ ЦђРЧШИПЁМ­ СІАЁ СІРЯ ГєРК АЭЕЕ ОЦДбАЭ ААРКЕЅ, РЯДм СІАЁ РЧРхРИЗЮ МБУтЕШ АЭ ААНРДЯДй.^^;;\r<BR>ИеРњ РЧРх МБУтПЁ ТќПЉЧи СжНХЕЅ БэРК АЈЛчИІ ЕхИГДЯДй.\r<BR>\r<BR>ЦђРЧШИИэРК ЦђРЧШИИІ АЁРх Рп ГЊХИГО Мі РжДТ ДмОюПЉОп Чв АЭРдДЯДй.\r<BR>ЧіРчДТ СІ РгРЧЗЮ &quot;DraBro&quot; (Dragon BrothersРЧ СйРгИЛ) ЖѓАэ СЄЧЯПДСіИИ, ДйИЅ ЦђРЧПј ПЉЗЏКаЕщРК М­ЗЮ ДйИЅ Л§АЂРЛ АЁСіАэ АшНУИЎЖѓ КОДЯДй.\r<BR>\r<BR>ЦђРЧШИ ННЗЮАЧЕЕ СІ РгРЧЗЮ &quot;ЙЖФЁДТ АЭИИРЬ ЛьБцРЬДй!&quot; ЖѓАэ СЄЧЯПДНРДЯДй.\r<BR>РЬАЭПЁ ДыЧиМ­ЕЕ ПЉЗЏ ССРК РЧАпРЛ АЁСіАэ АшНУИЎЖѓ КОДЯДй.\r<BR>\r<BR>ПЉЗЏКаЕщРЧ ИЙРК РЧАп АГСјРЛ КЮХЙЕхИГДЯДй.\r<BR>\r<BR>АЈЛчЧеДЯДй.\r<BR>\r<BR>-= ФЩЛчИЃ РЮ ЕхЖѓКъЗЮ..','2002-04-03 23:03','211.192.90.111','Kesarr');
INSERT INTO posts VALUES (175,121,101,1080,'ОШГчЧЯММПф?\r<BR>ЦђРЧШИ РЧРхРИЗЮ МБУтЕШ ФЩЛчИЃРдДЯДй.\r<BR>\r<BR>РЧРхРК ЦђРЧШИРЧ РчСЄ Сп РЯКЮИІ Рќ ШИПјПЁАд КаЙшЧЯАХГЊ РчСЄРћРИЗЮ КЮСЗЧб ШИПјПЁАд РчСЄ СіПјРЛ ЧиСй Мі РжНРДЯДй.\r<BR>КаЙшИІ ЧЯАд ЕЧИщ БЙЗТПЁ ЕћЖѓ КёЗЪЧЯПЉ КаЙшАЁ ЕЧДТЕэ ЧеДЯДй.\r<BR>\r<BR>ЦђРЧШИ РчСЄРК ЦђРЧШИ ШИПјЕщЗЮКЮХЭ ХЯИЖДй РкЕПРИЗЮ АХЕЮОюСіДТ ШИКёПЭ, РкПјЧЯПЉ ЦђРЧШИПЁ БтКЮЧЯДТ БтКЮБнРИЗЮ УЄПіС§ДЯДй.\r<BR>ОЦИЖЕЕ РЬЗЏЧб ЦђРЧШИ РчСЄРЬ ЧСЗЮСЇЦЎ МіЧр ЕюПЁ ЛчПыЕЧДТЕэ ЧеДЯДй.\r<BR>\r<BR>БзЗЏГЊ ШИПјЕщРЬ СїСЂ И№РК РчСЄРЮИИХ­ ЧЪПфЧв ЖЇЖѓИщ О№СІГЊ ШИПј ПЉЗЏКаПЁ ДыЧб РчСЄ СіПјРЛ ОЦГЂСі ОЪРЛ АЭРдДЯДй.\r<BR>\r<BR>ЦђРЧШИ РчСЄ КаЙшДТ РЯДм ЧЯЗчПЁ ШИПјМі*10000PPИІ Рќ ШИПјПЁАд КаЙшЧЯАэ, СІАд РќЙЎРЛ КИГЛ ПфУЛЧЯДТ ШИПјПЁАдДТ ЧЯЗчПЁ 2КаБюСіИИ ШИПјМі*5000PP ЧбЕЕГЛПЁМ­ ЧЪПфЧбИИХ­ РчСЄ СіПјРЛ ЧЯПЉ ЕхИЎАкНРДЯДй.\r<BR>\r<BR>РЬАпРЬ РжРИНХ КаРК О№СІЖѓЕЕ РЧАпРЛ АГСјЧи СжНУИщ УжДыЧб МіЗХЧЯАкНРДЯДй.\r<BR>\r<BR>АЈЛчЧеДЯДй.\r<BR>\r<BR>-= ФЩЛчИЃ РЮ ЕхЖѓКъЗЮ..','2002-04-03 23:14','211.192.90.111','Kesarr');
