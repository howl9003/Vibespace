INSERT INTO posts VALUES (2268,1036,190,2017,'Кі ЗљДТ....СпАХИЎ ЙЋБт,\r<BR>\r<BR>ФГГэ, ЧСЗЮСЇХИРЯ(ХКЕЕЙЋБт),АЁПьНКАЧ,ЗЙРЯАЧ,ИХНКЕхЖѓРЬЙі ЕюРК БйСЂРќ ЙЋБтРдДЯДй.\r<BR>\r<BR>ЙЬЛчРЯРК РхАХИЎ ЙЋБт.\r<BR>\r<BR>\r<BR>\r<BR>ЙЬЛчРЯРК ГЏОЦАЁДТ МгЕЕАЁ ДРИГДЯДй.\r<BR>\r<BR>БзЗЁМ­ ЛчСЄАХИЎАЁ БІТњРК КіРЬЖћРК КёНСЧб НУБтПЁ ИТСв.(КіРК МгЕЕАЁ ЙЬЛчРЯ 20ЙшРдДЯДй.)\r<BR>\r<BR>ДыНХПЌЛчЗТРЬ ОіУЛГЊАд ДРИГДЯДй.\r<BR>\r<BR>ЙнЙАСњ ЙЬЛчРЯ ЧбДы НђДы ИХНКЕхЖѓРЬЙі 10Йј ГбАдНюСв.\r<BR>\r<BR>\r<BR>ХКЕЕЙЋБтДТ ГЏОЦАЁДТ МгЕЕЕЕ БзРњБзЗИАэ АХИЎЕЕ ТЊСіИИ\r<BR>\r<BR>ОЦСж ПЌЛчЗТРЬ ССНРДЯДй.\r<BR>\r<BR>2ДмАшПЁМ­ СІРЯ ССРК ХКЕЕЙЋБтДТ ИХНКЕхЖѓРЬЙіСв.\r<BR>\r<BR>\r<BR>\r<BR>ЙнЙАСњ ЙЬЛчРЯААРКАцПьПЁ ДчКаАЃ УжА­РИЗЮ БКИВЧЯАкСіИИ\r<BR>\r<BR>РњААРКАцПьДТ РќЗЋРЛ РЬЗИАд ТЅКМ АшШЙРдДЯДй.\r<BR>\r<BR>\r<BR>\r<BR>ЧдП­ :\r<BR>\r<BR>         ЙЬЛчРЯЧдДы       ЙЬЛчРЯЧдДы\r<BR>\r<BR>               КіЧдДы    КіЧдДы\r<BR>\r<BR>               БйАХИЎЙЋБтЧдДыЕщ\r<BR>\r<BR>ЙЬЛчРЯЧдДыААРКАцПь БйАХИЎЙЋБт 1АГ, БзПмПЃ РќКЮ ЙЬЛчРЯЗЮ УЄПьАэ\r<BR>\r<BR>Е№ЙйРЬНКДТ ECMРИЗЮ ЙЬЛчРЯРЧ ЧЧЧиИІ УжМвШ­.\r<BR>\r<BR>АјАЃРЬ ГВДТДйИщ А­Ш­МБУМИІ ДфДЯДй.\r<BR>\r<BR>ОЦИгДТ ЙнЙАСњ ОЦИгЗЮ ЙЬЛчРЯРЧ ЕЅЙЬСіИІ СйРдДЯДй.\r<BR>\r<BR>\r<BR>\r<BR>\r<BR>КіЧдДыДТ ЙЬЛчРЯ ЧдДыИІ ЕкПЁМ­ ЙщОїЧеДЯДй.\r<BR>\r<BR>ОЦИгДТ БйСЂРќРЛ РЇЧиМ­ РкАЁШИКЙ ХЉИЎНКХЛЗЮ ЧЯАэ\r<BR>\r<BR>Е№ЙйРЬНКДТ А­Ш­МБУМ.\r<BR>\r<BR>КіРК 3ДмАш КіРИЗЮ ДоОвНРДЯДй. СпЗТОчРкКі.\r<BR>\r<BR>\r<BR>\r<BR>\r<BR>ШФП­. БйАХИЎ ЙЋБт ЧдДы.\r<BR>\r<BR>ОЦИгДТ БйСЂРќПы РкАЁШИКЙ ХЉИЎНКХЛ\r<BR>Е№ЙйРЬНКДТ А­Ш­МБУМ\r<BR>ЙЋБтДТ РќКЮ ИХНК ЕхЖѓРЬЙі(3ЗЙКЇ БйСЂРќ ЙЋБт АГЙпРЬ ОЦСї ИжОњНРДЯДй. 2ДмАшГЊ ГВОвГзПф.)\r<BR>\r<BR>\r<BR>\r<BR>\r<BR>РќП­Ањ 2П­РК ГыИжЗЮ СјАнЧеДЯДй.\r<BR>\r<BR>3П­РК ЦаГЪЦЎЗЙРЬЦЎЗЮ ЧиМ­\r<BR>\r<BR>РћРЧ ШФП­ЗЮ ЦФАэЕщОю АјАнЧеДЯДй.\r<BR>\r<BR>\r<BR>\r<BR>РЬЗИАд Л§АЂРЛ ЧпДТЕЅ..\r<BR>\r<BR>ОЦСї И№ИЃАкГзПф. ХЙЛѓАјЗаРИЗа ОЦЙЋАЭЕЕ ОШЕХДЯБю-_-\r<BR>\r<BR>\r<BR>\r<BR>ЧіРч МјОчЧдРИЗЮ 1СјРЛ БИМКЧв ПЙСЄРЬАэ\r<BR>\r<BR>2СјЕЕ МјОчЧд ЖЧДТ БИУрЧдРИЗЮ Чв АшШЙРдДЯДй.\r<BR>\r<BR>3СјРК ОЦСї СІДыЗЮЕШ БтМњАГЙпРЬ ОШЕЧОюМ­\r<BR>\r<BR>МјОчЧд ЧЯБф ОЦБѕАэ...БИУрЧдРЬГЊ ОЦДЯИщ ОЦПЙ\r<BR>\r<BR>ЧСИЎБъРЛ ДоОЦМ­ ЙАЗЎАјММИІ Чв Л§АЂЕЕ РжНРДЯДй.\r<BR>\r<BR>','2002-04-07 23:40','211.203.222.154','ИѓЕЅРЮ');
