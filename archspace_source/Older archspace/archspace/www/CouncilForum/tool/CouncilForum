INSERT INTO posts VALUES (161,110,84,864,'1. ЧдДы\r<BR>\r<BR>  РкРпЧб ЧдДыДТ РжДТАЭРЬ ССДй.\r<BR>\r<BR>   РЬ ЧдДыРЧ ОВРгЛѕДТ\r<BR>\r<BR>   1. ХНЛч\r<BR>\r<BR>   ОЦСж ССРК ХЧРЬДй\r<BR>\r<BR>   АЁДЩЧб РкСж ЕщЗС ХНЛчИІ ЧиМ­ ЧрМКРЛ ОђДТЦэРЬ ССДй.\r<BR>\r<BR>   2. РќХѕ\r<BR>\r<BR>   УЪЙнРќХѕДТ ЧбАГГЛСі 2АГРЧ РќХѕКЮДыЗЮ ГЁГЛДТАЭРЬ ССДй.\r<BR>\r<BR>   ОЦХЉНКЦфРЬНКАЁ ЙйВюБт РќПЁДТ ЙЋЧбДыЗЮ АјАнЧвМі РжОњРИГЊ СіБнРК БЙЗТРИЗЮ ТЉИАДй..\r<BR>\r<BR>   БзЗЏГЊ ЧбЙј АјАнЧЯБИ ДйНУ АјАнЧвМі РжДТЖЇАЁ РжДТЕЅ\r<BR>\r<BR>   БзЖЇ ГВДТ ЧдДыАЁ ОјРИИщ ТЅСѕГ­Дй\r<BR>\r<BR>   БзЗЏЙЧЗЮ РкРпЧб КёЧрБтЕщЗЮ ЧдДыИІ ИИЕщОю Гі\r<BR>\r<BR>   ЧрМКЕћИдБтИІ ЧвМі РжЕЕЗЯ ЧиОп ЧбДй.\r<BR>\r<BR>   РќХѕЧдДы\r<BR>\r<BR>   РќХѕЧдДыРЧ БтКЛРК РЯДм ЧдДы ХЌЗЁНКАЁ ГєОЦОп ЧбДйДТАЭРЬДй..\r<BR>\r<BR>   РкНХРЬ ИИЕщМі РжДТ ХЌЗЁНКПЁМ­ КИХы 1АГ ГЛСі 2АГ\r<BR>\r<BR>   ГЗРК ХЌЗЁНКРЧ МБДмРИЗЮ СжЗТ РќХѕКЮДыИІ ИИЕхДТ АЭРЬ ССДй\r<BR>\r<BR>2. ПмБГ\r<BR>\r<BR>  УЪЙнПЁ ПмБГРЧ СпПфМКРК ШФЙнКИДйДТ ГЗСіИИ\r<BR>\r<BR>  БзЗЁЕЮ ЙЬИЎ ЙЬИЎ ЕПИЭРЛ ИЮОю ГѕРИИщ\r<BR>\r<BR>  ГЊСпПЁ ЛѓОїРИЗЮ ЕщОюПРДТ PP(Produce Point)АЁ \r<BR>\r<BR>  НђНђЧЯБтЖЇЙЎПЁ РЏПыЧЯДй.\r<BR>\r<BR>3. РќРя\r<BR>\r<BR>  ОЦБю ЧдДыПЁМ­ ИЛЧпЕэРЬ\r<BR>\r<BR>  СжЗТРИЗЮ ОЕБИ ЖГАХСі ЧдДыЗч ЧрМК ЕћИдДТАЭРЬ АЁРх ССДй\r<BR>\r<BR>4. ГЛСЄ\r<BR>\r<BR>  ГЛСЄРК ЦЏШї СпПфЧЯДйАэ КММі РжДй.\r<BR>\r<BR>  ОЦХЉИоРЬСіИІ Чб ЛчЖїРЬ РжРЛСі И№ИЃДТЕЅ\r<BR>  \r<BR>  ОЦХЉНКЦфРЬНКДТ ПЌБИАЁ РкЕПРИЗЮ ЕШДй..\r<BR>\r<BR>  БзЗЏГЊ СОСЗСіЧЅЖѓДТ АГГфРЬ РжДТЕЅ..\r<BR>\r<BR>  ПЉЗЏ СОСЗСіЧЅАЁ РжРИГЊ УЪЙнПЁ СпПфЧбАЭРК\r<BR>\r<BR>  Л§ЛъАњ ПЌБИЖѓАэ ЧвМі РжДй\r<BR>\r<BR>  ИеРњ УГРН НУРлЧвЖЇПЁДТ АцСІСЄУЅПЁМ­\r<BR>\r<BR>  АјОїРИЗЮ РќШЏЧи\r<BR>\r<BR>  РЯДм PPИІ ШЎКИЧЯАэ АЧЙАРЛ СўАд ГіЕаДй\r<BR>\r<BR>  БзИЎАэ Ор 200ХЯ ШФ КЮХЭДТ \r<BR>\r<BR>  АЁДЩЧбЧб ПЌБИИІ РЯТя ГЁГОМі РжЕЕЗЯ\r<BR>\r<BR>  АцСІСЄУЅРЛ ПЌБИЗЮ ЙйВу ГѕДТДй\r<BR>\r<BR>  СпАЃСпАЃПЁ ЕЗРЬ КЮСЗЧЯИщ Л§ЛъРИЗЮ ЙйВйАэ\r<BR>\r<BR>  П­ЙоОЦМ­ РќХѕИИ ЧЯАэ НЭРИИщ \r<BR>\r<BR>  БКЛчЗЮ ЙйВйИщ ЕШДй..\r<BR>\r<BR>  БзИЎАэ ЖЧЧб СпПфЧбАЭРК ГВДТ ЕЗРЬ РжРЛЖЇИЖДй\r<BR>\r<BR>  ПЌБИХЧРИЗЮ ЕщОюАЁМ­\r<BR>\r<BR>  ЕЗРЛ ХѕРкЧиОп ЧбДйДТ АЭРЬДй..\r<BR>\r<BR>  ЕЗРЛ ХѕРкЧЯИщ ПЌБИ СОСЗСіЧЅАЁ +3 РЬ ЕЧДТЕЅ\r<BR>\r<BR>  РЬДТ ОЦСж ГєРК МіФЁРЬДЯ\r<BR>\r<BR>  ЕщОюПУЖЇИЖДй ЖГОюСЎ РжГЊ ШЎРЮЧиМ­\r<BR>\r<BR>  УЄПі ГжОюОп ЧбДй..\r<BR>\r<BR>  ПЌБИПЁ ЕЗОВДТАЩ ОЦБюПі ЧиМ­ДТ ГЊСпПЁ ЧЧКЛДй\r<BR>\r<BR>  ЖЧЧб СЛ СіГЊЦэ ЧСЗЮСЇЦЎЖѓДТ АЭРЛ ЛьМі РжДТЕЅ\r<BR>\r<BR>  РЬАЭЕЕ ЛьМі РжРЛЖЇ ЛчГѕДТАЭРЬ ССДй..\r<BR>\r<BR>\r<BR>-----------\r<BR>\r<BR>РЬЛѓ УЪЙн СЖО№РЬОњНРДЯДй\r<BR>\r<BR>БУБнЧбСЁРЬ РжРИИщ ИЎЧУ ДйММПф\r<BR>','2002-04-03 22:38','211.54.52.110','ОЦРкЙйЖѓ');
