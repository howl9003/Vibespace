INSERT INTO posts VALUES (1355,602,28,285,'ГЛСЄПЁДТ АцСІСЄУЅ,ЧрМКАќИЎ,ПЌБИ,ЧСЗЮСЇЦЎ,\r<BR>ЙщМ­АЁ РжНРДЯДй.\r<BR>\r<BR>-АцСІСЄУЅРК БеЧќАњ АјОї,БКЛч,ПЌБИАЁ РжНРДЯДй.\r<BR>КИХыРК БеЧќРИЗЮ ЧЯДТАд ССНРДЯДйИИ ИИОр ЛЁИЎ\r<BR>ЧЯАэ НЭРКАд РжДйИщ ДйИЅ ЧЯГЊИІ МБХУЧЯДТ ЙцЙ§\r<BR>ЕЕ РжНРДЯДй. ЧЯСіИИ Бз ДыНХПЁ ДйИЅ КаОпДТ\r<BR>ЕкУГСіАд ЕЧДЯ Рп Л§АЂЧЯМХОп ЧеДЯДй.\r<BR>\r<BR>-ЧрМКАќИЎДТ И№ЧрМКАњ БзПм ХНЛчГЊ АјМКРИЗЮ\r<BR>ОђРК ЧрМКРЛ АќИЎЧЯДТ АЬДЯДй. БзАЭРЛ КИИщ\r<BR>АЁРх СпПфЧб АЭРК ШЏАцАњ РкПјРЬЖѓАэ Л§АЂЕЧДТЕЅ\r<BR>ШЏАцРК ХѕРкИІ ХыЧи АГМБЧв Мі РжРИЙЧЗЮ РкПјРЬ\r<BR>ЧГКЮЧЯАэ ХЉБтАЁ ХЉИщ БтКЛРћРИЗЮ ССДйАэ КМ Мі\r<BR>РжНРДЯДй. \r<BR>ЧрМКММКЮЧзИёПЁ ЕщОюАЁКИИщ АЧМГКёРВ,ХѕРкИІ \r<BR>АсСЄЧв Мі РжНРДЯДй.\r<BR>АЧМГКёРВРК КИХы 40,30,30 БтКЛРИЗЮ ЕЧОюРжДТЕЅ\r<BR>ИИОр РкПјРЬ КЮСЗЧЯДйИщ ПЌБИМвГЊ, БтСі РЇСжЗЮ\r<BR>ЧГКЮЧЯДйИщ АјРхРЛ Дѕ СўЕЕЗЯ КёРВРЛ СЖСЄЧЯДТ\r<BR>АЭРЬ ССНРДЯДй.\r<BR>ХѕРкДТ ЧрМКРЧ ШЏАцРЛ АГМБНУХААэ УжДыРЮБИИІ\r<BR>ДУИЎДТ ПЕЧтРЛ СнДЯДйИИ...\r<BR>ЕЗРЬ ВЯ ЕщОюАЁДТ АЭРЛ ДРГЅ Мі РжНРДЯДй.\r<BR>ЧЯСіИИ ЕщОюАЃИИХ­ ГЊСпПЁ КИДфРЛ ЙоАд ЕЧДЯ\r<BR>БиЧбШЏАцРЬГЊ ЛьРЮРћ ШЏАцПЁМ­ЕЕ НЧИСЧЯСі\r<BR>ИЖНУАэ ЙиКќСј ЕЖПЁ ЙАКзДТ НЩСЄРИЗЮ ВйСиШї\r<BR>ХѕРкЧЯНЪНУПР. О№СЈАЁДТ ЙЬЗЁПЁ КИДфЙоАд ЕЫДЯДй\r<BR>ПЌБИДТ БтКЛРћРИЗЮ РкРЏПЌБИРЬСіИИ РкНХРЬ ПјЧЯ\r<BR>ДТ ПЌБИИІ СіСЄЧиМ­ ИеРњ ПЌБИЧв Мі РжНРДЯДй.\r<BR>ЦЏШї ПЌБИ ЙиПЁ КИИщ ЧСЗЮСЇЦЎГЊ ЙЋБтААРК ЧзИё\r<BR>РЬ РжДТ ПЌБИЕщРК ЙЋУД СпПфЧб АЭРЬДЯ БзЗБ АЭРК\r<BR>ЙнЕхНУ ЧЯНУБц ЙйЖјДЯДй.\r<BR>ПЉБт НКХГ ЦЎИЎ СЄИЎАЁ Рп ЕЧОюРжДТ ШЈЦфРЬСіАЁ\r<BR>РжОюМ­ МвАГЧи ЕхИГДЯДй.\r<BR><!-- BBCode auto-link start --><a href=\"http://nightbride.org/archspace/tech-tree.php\" target=\"_blank\">http://nightbride.org/archspace/tech-tree.php</a><!-- BBCode auto-link end -->\r<BR>ЧСЗЮСЇЦЎДТ РњЕЕ БИРдЧб ЧСЗЮСЇЦЎАЁ ОјОюМ­ Рп \r<BR>И№ИЃАкСіИИ ЦђРЧШИИІ ХыЧи СІАЁ НЧЧрЧб ЧСЗЮСЇЦЎ\r<BR>ИІ КМ ЖЇ ПЌБИАЁ СјЧрЕЧАэ ЧСЗЮСЇЦЎИІ Чв Мі Рж\r<BR>ДТ ПЌБИИІ ЧпРЛ ЖЇ PPИІ ГЛАэ БИРдЧЯДТ АЭ АА\r<BR>НРДЯДй. ЧЯСіИИ ШЎНЧЧЯСі ОЪРИДЯ ГЊСпПЁ СЄШЎШї\r<BR>ОЦНУДТ КаРК ИЎЧУ ДоОЦСжММПф. ^^;\r<BR>ЙщМ­ДТ РќЙнРћРЮ ШхИЇРЛ КИПЉСжДТ АЬДЯ