INSERT INTO posts VALUES (2001,897,178,761,'ОЦХЉНКЦфРЬНКИІ ЧдПЁ РжОюМ­ ОЫОЦЕЮОюОпЧв АЃЗЋЧб ЦС\r<BR>\r<BR>- ЧдДыРќРЧ НТЦаРЧ ПфРЮРК ГВОЦРжДТ ЧдМБРЧ МіПЁ ДоЗС РжДй. ОчУјПЁ ЧдДыАЁ ГВОЦ РжРИИщ КёБтАдЕЧАэ, Бз РЬ ПмРЧ АцПь ЧдДыАЁ ГВРК ТЪРЬ НТИЎЧЯАдЕШДй. ГВРК ЧдДыПЃ Х№АЂЧЯДТ ЧдДыДТ ЦїЧдЕЧСі ОЪДТДй.\r<BR>- БИЧќЧдМБРЛ ЦѓБтЧвЖЇДТ АЂ ЧдМБРЧ МГАшПЗПЁ РжДТ ЦѓБт ЙіЦАРЛ ДЉИЅДй.\r<BR>- ЧдМБАЧСЖИІ КќИЃАдЧЯБтРЇЧиМБ БКЛчСОСЗСіЧЅИІ ГєРЬАХГЊ , ЧдМБАЧСЖПЁ PPИІ ХѕРкЧЯИщ ЕШДй.\r<BR>- И№Еч PPДТ ХѕРкЧб СяНУ УыМвАЁ КвАЁДЩЧЯДй. АэЗЮ ХѕРкНУ ОзМіДТ СЄШЎШї ШЎРЮЧиОпЧбДй.\r<BR>- СОСЗСіЧЅЖѕ АЂ СОСЗРЬ АњЧа/БтМњ/БКЛчЕю РќЙнПЁ АЩУФМ­ СіДб ПьП­МКРЛ ГЊХИГЛДТ СіЧЅРЬДй.\r<BR>- ПЌБИБтМњСп ОЯЛьРЛ ЛчПыЧЯИщ НУРќБЙРЧ ЧдДы ЛчЗЩАќРЛ ОЯЛьНУХГМіЕЕ РжДй.\r<BR>- ЧрМКСпПЁ АЁРх ССРК АЭРК ЧзЗЮБГТїСЁРЛ СіДбЧрМКРЬДй БГПЊРИЗЮРЮЧб МіРдРЬ БиДыШ­ ЕШДй.\r<BR>- ЕПИЭРК ЧљСЄСІРЧИІ ЛѓДыАЁ ЙоОЦЕщРИИщ ЕПИЭРЬ ЕШДй.\r<BR>- ЧСЗЮСЇЦЎДТ ЙЋСЖАЧ БИРдЧбДйАэ ССРК АЭРЬ ОЦДЯДй. ЧбЙј РЭШљ ЧСЗЮСЇЦЎДТ ГЁБюСі АЁДТЕЅ, АЂ ЧСЗЮСЇЦЎИЖДй РхДмСЁРЬ РжБтПЁ НХСпЧЯАд БИРдЧЯАэ ЛчПыЧиОпЧбДй.\r<BR>- ОЯНУРхПЁМ­ ПЌБИБтМњРЬГЊ СіШжАќ Йз ЧСЗЮСЇЦЎГЊ СІБЙПЁМ­ ГЛГѕРК ЧрМКЕюРЛ БИРдЧвМі РжДй.\r<BR>- СІБЙРЧ УбЕЖПЁАд ГњЙАРЛ ЙйФЁИщ МБЙАРЛ СжАХГЊ, НХКаРЛ ПУЗССйМіЕЕ РжДй. ЧуГЊ Гб ГЗРИИщ ОУЧєЙіИЎАдЕШДй.\r<BR>\r<BR>','2002-04-06 22:16','211.208.193.101','гољг№ЈЯа');
