INSERT INTO posts VALUES (1389,621,28,285,'ЦђРЧШИ ХѕЧЅДТ РЧРхРЛ МБУтЧЯДТ АЬДЯДй. ИИОр\r<BR>СіБн ПЉЗЏКаЕщРЬ ДйИЅ КаРЛ ТяРИНХДйИщ ОѓИЖ ШФ\r<BR>ЙйВя РЧРхРЛ КМ Мі РжРЛ АЬДЯДй. КЮЕ№ БзЗБ РЯРЬ\r<BR>ЙњОюСіСі ОЪБц~\r<BR>АЁРд ПфУЛРК ДйИЅ ЦђРЧШИЗЮ ЕщОюАЁАэ НЭРЛ ЖЇ\r<BR>ЛчПыЧЯДТ АЬДЯДй. ОюРЬ,ОюРЬ~ ДЉИЃСі ИЛОЦПф~\r<BR>ЕЖИГМБО№РК НКНКЗЮ ЛѕЗЮПю ЦђРЧШИИІ ИИЕщАэРк\r<BR>Чв ЖЇ ЛчПыЧЯДТ АХСіИИ ЧЪПфЧб ПЌБИАЁ РжНРДЯДй.\r<BR>УЪЙнПЁ Чв Мі РжДТ ПЌБИРЬЙЧЗЮ РЬЙЬ ЕЧОюРжДТ \r<BR>КаЕщЕЕ АшНУАкБКПф.\r<BR>БтКЮДТ ЦђРЧШИПЁ PPИІ БтКЮЧЯДТ АЭРдДЯДй.\r<BR>РЧРх ИоДКДТ РЧРхИИ ЛчПыЧв Мі РжНРДЯДй. ^^;\r<BR>РсНУ МвАГЧЯРкИщ И№Еч ШИПјПЁАд РЯСЄЧЯАд КаЙшЧи\r<BR>СжДТ КаЙш, И№ЕЮПЁАд ПЕЧтРЛ ГЂФЃДйАэ Л§АЂРЬ \r<BR>ЕхДТ ЧСЗЮСЇЦЎ(БГПЊ МіФЁАЁ ПУЖњДТСі СЛ ИЎЧУ\r<BR>ДоОЦСжММПф! УЪЙнРЮЕЅ БГПЊ МіФЁАЁ ПУЖѓРжДйИщ\r<BR>ОЦИЖ ПЕЧтРЬ ГЂФЃ АЭРЬАкСЎ?), Чб ЛчЖїПЁАд СжДТ\r<BR>РчСЄСіПј, ЦђРЧШИ РЬИЇАњ ННЗЮАЧ КЏАц ЕюРЬ РжНР\r<BR>ДЯДй. РЯДм РЬИЇРК ДйХЉ ОЦИгЖѓАэ ЧпДТЕЅ Дѕ СС\r<BR>РК РЬИЇРЬ РжДйИщ О№СІЕчСі ШЏПЕЧеДЯДй.\r<BR>ПьИЎ ЦђРЧШИДТ ПьСжСІРЯРЛ ИёЧЅЗЮ ЖйАэ РжНРДЯДй\r<BR>ГЊИгСіДТ ЧУЗЙРЬОю ПЕРд(ДЉАЁ УпУЕЧи СжММПф)Ањ \r<BR>ДйИЅ ЦђРЧШИАЃРЧ ПмБГАЁ РжНРДЯДй.\r<BR>БзЗБЕЅ ШАЕПРЛ РкСж ЧиСжМХОп ДйИЅ ЦђРЧШИПЭ Кй\r<BR>ОюКМ ХйЕЅ... ДйИЅ КаПЁАд ЧЧЧиАЁ АЅБюКС ЧЯСњ\r<BR>ИјЧЯАкБКПЉ.\r<BR>И№ЕЮЕщ П­НЩШї ЧеНУДй!','2002-04-05 14:13','211.202.189.213','НКХИРЬГЪ');
