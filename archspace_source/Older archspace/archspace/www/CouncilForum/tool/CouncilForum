INSERT INTO posts VALUES (2116,950,312,397,'ЧУЗЉХЗ......\r<BR>....МіФЋХИ УЂБтКД,. ДдРЧ БлРдДЯДй\r<BR>\r<BR>1.normal.\r<BR>ЧдДыДТ РћРЬ ЛчАХИЎПЁ ЕщОюПУЖЇБюСі РќСјЧбШФ РћАњ СЂРќРЛ ЙњРЮДй.\r<BR>РЬЕПРК ЧдДыСпОгАњ 1500РЧ АХИЎИІ РЏСіЧбУЄЗЮ РЬЕПЧбДй.\r<BR>\r<BR>2.formation\r<BR>РЬ ИэЗЩРЛ ЙоРК ЧдМБЕщРК БтКЛРћРИЗЮ СжОюСј ЧдП­(ЦїИоРЬМЧ)РЛ РЏСіЧи ГЊАЃДй.\r<BR>ГыИж ИэЗЩАњ ААРЬ РќСјЧЯГЊ, ЧдДыСп СІРЯ ДРИА ЧдПЁ ИТУпОю РќСјЧбДй.\r<BR>ЦїИоРЬМЧРЛ БњАдЕЧДТМіЕЕ РжБф ЧЯДй.(..АЉРкБт РЂМвИЎ?)\r<BR>\r<BR>\r<BR>3.Penetrate\r<BR>ЦаГЪЦЎЗЙРЬЦЎЗЮ ИТУпОюСј ЧдЕщРК РћРЧ РќП­РЛ ЖеАэ ЕкЗЮ ЕЙОЦЕщОюАЁ ЙнРќ&amp;ЧљАјЧбДй.\r<BR>Дм, Рћ РќУМИІ ЖеАэ СіГЊАЁБт РќБюСі БзЕщРК ЙнРќЧЯСі ОЪРЛАЭРЬДй.\r<BR>(..СпОгЕЙЦФ ЙшШФРќАГГФ -_-)\r<BR>\r<BR>4.Flanking.\r<BR>ЧљАјРЛ МБХУЧпДйИщ, ЧУЗЙРЬОюДТ ЧдДыЙшФЁИІ НХСпШї ЧиОпЧбДй.\r<BR>Ш­ИщРЧ РЇТЪ Р§ЙнПЁ РЇФЁЧб ЧдДыДТ РЇТЪРИЗЮ ЕЙОЦАЅАЭРЬАэ\r<BR>ЧЯДм Р§ЙнПЁ РЇФЁЧб ЧдДыДТ ЧЯДмРИЗЮ ЕЙОЦАЅАЭРЬДй.\r<BR>\r<BR>ЧдДыДТ РћЧдДыРЧ ШФЙцРИЗЮ ГбОюАЅЖЇБюСі СжКЏРЛ ЕЙОЦ РЬЕПЧв АЭРЬДй.\r<BR>\r<BR>5.Reserve \r<BR>ПЙКё ЧдДыДТ ХИ ЧдДыРЧ 3/4 МгЕЕЗЮ РќСјЧбДй.\r<BR>РќСјЧЯДТСпПЁ ИЖСжФЃ РћЧдАњДТ РќХѕИІ ЙњРЬИч\r<BR>ЦїИоРЬМЧ ИэЗЩРЛ АЁСј ЧдДыСп РќИъЧб ЧдДыАЁ РжРИИщ\r<BR>\r<BR>КѓАјАЃРЛ ИоВм АЭРЬДй.\r<BR>\r<BR>6.Assult.\r<BR>А­НР(ОюМГЦЎ)РИЗЮ ИэЗЩЧб ЧдДыЕщРК Рћ ЧдП­РЧ 50%БюСіИИ ЕЙЦФЧбДй.\r<BR>БзИЎАэ РќЙцРЧ Рћ(Ся ШФП­РЧ РћРЬ ЕЧАкСв.)РЛ АјЗЋЧбДй.\r<BR>\r<BR>РЬ ЧдДыДТ Рћ ЧдП­РЧ 50%РЬЛѓРЛ ЕЙЦФЧЯАХГЊ\r<BR>РћПЁАд АјАнЙоСі ОЪДТЧб(ПјЙЎРК АјАнЙоЕЕЗЯ ОаЗТРЛ ЙоСі ОЪДТЧб), АјАнЧЯСі ОЪРЛАЭРЬДй.\r<BR>\r<BR>\r<BR>7,Free\r<BR>Уж БйСЂ РћРЛ АјАнЧЯАэ, БзСпПЁ РЇЧшЧб РћРЛ УЃОЦ АјАнЧбДй.\r<BR>СјЧрАцЗЮДТ 1500РИЗЮ АсСЄЕЧОю РжДй.\r<BR>\r<BR>8. Stand Ground\r<BR>РЬ ИэЗЩРК ЙцОюУјПЁМ­ИИ АЁДЩЧЯДй.\r<BR>ЧдДыДТ РћРЬ ПЭМ­ СЂРќРЛ ЙњРЯЖЇБюСі ИиУпОю БтДйИАДй.\r<BR>РЬ ЧдП­РЬ БњСњМіЕЕ РжДТЕЅ(ДыУМ Пж?!)\r<BR>БњОюСіИщ ГыИж ИэЗЩУГЗГ РќСјЧи НЮПяАЭРЬДй.\r<BR>\r<BR>ШЄНУ ЛчАХИЎ ГЛПЁ ААРК РћРЬ ЦїТјЕЧИщ\r<BR>ЧдДыДТ СІРЯ РЇЧшЧб РћРЛ С§СпЦїАнЧЯАд ЕЩ АЭРЬДй.\r<BR>(ССБКПф. ЙЬЛчРЯ ЧдЕщРЬ НзОЦГѕРИИщ -_-)\r<BR>\r<BR>\r<BR>\r<BR>','2002-04-07 02:52','211.187.226.24