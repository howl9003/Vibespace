INSERT INTO posts VALUES (1682,749,168,654,'СіБн ПЉЗЏ ЦђРЧПјДдЕщРЬ ПЌБИПЭ БЙЗТНХРхПЁ ИЙРК ШћРЛ БтПяРЬАэ РжРЛАЬДЯДй\r<BR>\r<BR>БзЗБЕЅ ПьИЎАЁ ОЦЙЋЗБ ПЌБИЕЕОјРЬ РќРяРЛ ЧЯИщ СЛ БзЗИСв?\r<BR>БзЗЁМ­ СІАЁ ХИ ЦђРЧШИПЭ РќРяРЛ ОяСІЧЯДТ ЕПОШ ПЉЗЏКаРК БЙЗТРЛ НХРх НУХАНУАэ РќРяПЁ ДыЧи РЬАЭРњАЭ ПЌБИЧЯМХОп ЧеДЯДй\r<BR>\r<BR>БзЗЁМ­ ЦђРЧПјГЛПЁМ­ РќХѕРЧ БдФЂРК ДйРНАњ ААРЬ НЧСњРћРИЗЮ ЧЯДТЙцЧтРИЗЮ ЧеДЯДй.\r<BR>\r<BR>Дм РќРяРќПЁ ПЉБт АдНУЦЧРЬГЊ РЧРхРЮ РњДТ ОЫАэ РжОюОп ЧеДЯДй.\r<BR>\r<BR>1. ЦђРЧПј М­ЗЮАЃПЁ РЧАпРЛ УцКаШї БГЧбЧб ДйРН МБРќЦїАэЗЮ РкНХРЧ БЙЗТАњ РќМњ СіШжАќРЛ НУЧшЧбДй.\r<BR>\r<BR>2. РќХѕИІ ЧбШФПЁ АдНУЦЧПЁ БзПЁДыЧб КаМЎЕЕ ААРЬ ЧЯПЉ М­ЗЮАЁ АјРЏЧвМіРжДТ СіНФРИЗЮ ИИЕщОюСиДй.  \r<BR>\r<BR>3. М­ЗЮ ЛЉОбРЛМіРеДТ ЧрМКРК АЂБт ДйИЅ РќЙ§РИЗЮ 3АГ РЬЛѓРЬИщ ОШЕШДй.\r<BR>\r<BR>4. ШоРќРЛ ЧвАцПь Сј ЦэПЁМ­ ЙАРК СЖОрБнРК ЦђРЧШИАЁ РЯКЮ КИЛѓЧиСиДй.\r<BR>\r<BR>5. ЙЋТїКА КИКЙРЬГЊ АЈСЄРЧ НЮПђРК ОјОюОп ЧЯИч ЧрМКСжБтНФ РќРяРК ЛяАЁЧбДй.\r<BR>\r<BR>\r<BR>РЬЛѓРдДЯДй.\r<BR>\r<BR>И№ЕЮЕщ УжМБРЛ ДйЧиСжНУАэ ЙпРќРЬ АЁМгЕЧАд ЧЧЧЧИІ СіПјЧиЕхИЎАкНРДЯДй.','2002-04-06 06:51','211.191.235.65','ОЦЖѓЙЬНК');
