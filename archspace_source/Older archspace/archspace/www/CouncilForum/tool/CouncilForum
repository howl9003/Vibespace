INSERT INTO posts VALUES (49,38,72,739,'ОШГчЧЯММПф СМРК МвАпРЬСіИИ БзЕПОШ СІАЁ ДРВИКЛ ЧдРхРЧ ДЩЗТПЁ ДыЧиМ­ ИЛОИ ЕхЗС КИАкНРДЯ\r<BR>Дй. \r<BR>\r<BR>1. ЧдРхРЧ ПРИЅТЪПЁ ГЊХИГЊДТ A B C D ЕюРК ЧдРхРЧ РќУМ ЧдДыРЧ СіШжАќРЬ ЕЧОњРЛЖЇРЧ АЂАЂРЧ ЧдДыПЁ ШПАњИІ ГЊХИ ГЛДТ АЭ ААНРДЯДй.\r<BR>\r<BR>A Бо ЧдРхРК РќУМ ЧдДыРЧ ДЩЗќПЁ 10 % АЁЛъ ШПАњИІ СжАэ \r<BR>\r<BR>B Бо ЧдРхРК РќУМ ЧдДыРЧ ДЩЗќПЁ 5 % АЁЛъ ШПАњИІ СжАэ \r<BR>\r<BR>C Бо ЧдРхРК РќУМ ЧдДыРЧ ДЩЗќПЁ 0 % АЁЛъ ШПАњИІ СжАэ \r<BR>\r<BR>D Бо ЧдРхРК РќУМ ЧдДыРЧ ДЩЗќПЁ -5 % АЁЛъ ШПАњИІ СжДТ АЭРИЗЮ КИРдДЯДй.\r<BR>\r<BR>ПЉБтМ­ ИЛЧЯДТ ДЩЗќРЬЖѓДТ АЭРК АЂ ЧдДыРЧ РќУЄ ДЩЗТРЧ ЙпШж СЄЕЕИІ ИЛЧЯДТ АЭ ААНРДЯДй.\r<BR>\r<BR>ЙцОюРќЗЋРЛ БИМКЧвЖЇ ПЉЗЏ ЧдДыИІ ЙшФЁЧЯАэ БзСпПЁ БтЧдРЛ МГСЄЧЯДТ Ш­ИщРЬ ГЊПЩДЯДй.\r<BR>\r<BR>БзАїПЁМ­ A Бо ЧдРхСп РќУМ ЧдДыСіПј ДЩЗТФЁАЁ ГєРК ЧдРхРЛ БтЧдРЧ ЧдРхРИЗЮ ЙшФЁ ЧЯНХДйИщ ССРК ШПАњАЁ РжРЛАЭ ААНРДЯДй.\r<BR>\r<BR>ОЦТќ ДЩЗќРЬ 2 СОЗљ РжДТАд КИРЬМЬАкСіПф РЇПЁ РжДТ ДЩЗТРК ЧдРх АГКА ЧдДыРЧ ДЩЗТ ЙпШжЗЮ Л§АЂЕЧОю С§ДЯДй.\r<BR>\r<BR>РЬЛѓ ИЛРЬ БцОюСЎМ­ ГЊСпПЁ РЬОюМ­ ЧЯАкНРДЯДй.\r<BR>\r<BR>ЧуСЂААРК РЧАпРЬСіИИ ТќАэЧи СжМЬРИИщ ЧеДЯДй.\r<BR>\r<BR>\r<BR>\r<BR>\r<BR>**ПЉБтПЁ РћШљ РЧАпРК 100% РњШё ЛчАпРЬИч ПюПЕРкРЧ СЄУЅЕюРК ОЦДеДЯДй.','2002-04-03 15:58','211.186.126.249','Moira');
