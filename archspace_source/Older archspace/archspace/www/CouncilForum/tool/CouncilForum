INSERT INTO posts VALUES (352,217,154,1288,'ОШГчЧЯММПф. ЛѕЗЮРЬ ИжЙЬСІБЙ ЦђРЧШИРЧ РЧРхРЬ ЕШ redbeeРдДЯДй.\r<BR>ПьИЎ ЦђРЧШИРЧ ДчИщ ИёЧЅ Йз РќЗЋРћ ЙцЧтРК ДйРНАњ ААНРДЯДй.\r<BR>\r<BR>1. ПоТЪ ИоДК ЧЯДмКЮРЧ АдНУЦЧ/ЦђРЧШИ АдНУЦЧРЛ РћБи ШАПыЧиСжНУБт\r<BR>   ЙйЖјДЯДй.\r<BR>   РЬЙјПЁДТ И№ИЃНУДТ КаЕщРЬ ИЙОЦ РЯРЯРЬ ЕћЗЮ РќЙЎРЛ ЙпМлЧеДЯДйИИ,\r<BR>   ДйРНКЮХЭДТ ЦђРЧШИ ГЛРЧ И№Еч ГэРЧДТ ЦђРЧШИ АдНУЦЧРЛ ХыЧиМ­\r<BR>   СјЧрЧЯЕЕЗЯ ЧЯАкНРДЯДй.\r<BR>\r<BR>2. РЏЗТЧб ЦђРЧШИПЭ ЕПИЭ АќАшИІ ИЮОю, ИИОрРЧ АцПьПЁ ЙпЛ§Чв Мі \r<BR>   РжДТ РЇЧљРЛ ЛчРќПЁ ЙцСіЧЯАэ, ДѕКвОю БГПЊРЛ ХыЧи Л§Лъ ЦїРЮЦЎ\r<BR>   (pp)ИІ ДУИЎАэ, ЦђРЧШИРЧ ПмБГЗТРЛ ЧтЛѓНУХЕДЯДй.\r<BR>\r<BR>   Бз РЯШЏРИЗЮМ­ РКЧЯРќБт(#10) ЦђРЧШИПЁ ЕПИЭРЛ ИЮДТЕЅ МКАјЧпНРДЯДй. \r<BR>   ГЛСЄКЮКаРЛ РЏНЩШї КИНУИщ БГПЊ ppАЁ ДУОюГ­ АЭРЛ ШЎРЮЧЯНЧ Мі РжРЛ \r<BR>   АЬДЯДй.\r<BR>\r<BR>3. БКМв ЦђРЧШИПЭРЧ БГРќРЛ ХыЧб ММЗТ ШЎРхРЛ НУЕЕЧеДЯДй. РЬЗЏЧб\r<BR>   СЄУЅРК ММЗТШЎРхРЧ ЙАВПИІ ХЭМ­ ИжЙЬСІБЙ ЦђРЧШИГЛПЁМ­РЧ\r<BR>   ПьШЃИІ СѕСјЧЯДТЕЅЕЕ ЕЕПђРЬ ЕЩАЭРЬЖѓАэ Л§АЂЧеДЯДй.\r<BR>\r<BR>   ЧіРч Цњ(1851)ДдАњ ВПИЖЗЙОЦ (#1729)Дд, БзИЎАэ L.E.DЂтНКПЁЊЕЊо \r<BR>   (#1717)ДдРЬ ПьИЎ ЦђРЧШИГЛПЁМ­ДТ КёБГРћ ШАЙпЧб ШЎРхСЄУЅРЛ\r<BR>   МБХУЧЯАэ АшНХЕэ ЧбЕЅ, ЦђРЧШИ ГЛПЁМ­ДТ АЁБоРћ РќРяРЛ ЛяАЁЧпРИИщ\r<BR>   ССАкНРДЯДй. ОЦИЖЕЕ ЦњДдРК РЬЙЬ ЦђРЧШИГЛПЁ КАЗЮ ЛѓДыЧвИИЧб\r<BR>   ЛчЖїРЬ ОјРИИЎЖѓ Л§АЂЧеДЯДйИИ.. (ПєРН)\r<BR>\r<BR>   ЧіРч Untitled (#190), Untitled (#186)РЧ 2АГРЧ ЦђРЧШИПЭ\r<BR>   РќРяМБО№РЬ ЕШ ЛѓХТРдДЯДй. ПјЧЯНХДйИщ, Дѕ ИЙРК ЦђРЧШИИІ\r<BR>   ЛѓДыЗЮ РќРяМБО№РЛ ЧЯЕЕЗЯ ЧЯАкНРДЯДй.\r<BR>   (ГЪЙЋ ИЙОЦСіИщ ГЊСпПЁ ЛѓДыЧЯБт АяЖѕЧЯИЎЖѓ Л§АЂЧеДЯДйИИ)\r<BR>\r<BR>4. РќРг РЧРхДдВВМ­ ЦђРЧШИ РќУМРЧ ЧСЗЮСЇЦЎ ЧЯГЊИІ РЬЙЬ\r<BR>   МіЧрЧиЕЮНХ ЛѓХТРдДЯДй. РКЧЯ РкРЏ ХыЛѓ СЖОр ЧСЗЮСЇЦЎЗЮМ­\r<BR>   PP СѕАЁПЁ ЕЕПђРЬ ЕЧДТ ЧСЗЮСЇЦЎРЮЕЅПф. \r<BR>\r<BR>   РЬПЭААРЬ ЦђРЧШИ РќУМПЁ ЕЕПђРЬ ЕЧДТ ЧСЗЮСЇЦЎИІ ОеРИЗЮЕЕ\r<BR>   АшМгЧиМ­ СјЧрЧв АЭРдДЯДй. РЬИІ РЇЧи ЦђРЧШИПЁ БтКЮИІ\r<BR>   ОѓИЖАЃОП ЧиСжНУБц ЙйЖјДЯДй. ЦЏШї ММЗТРЬ СЛ ЕЧНУДТ\r<BR>   И№И№ДдЕщРК ИЙРЬ ЧиСжМХЕЕ ^^;\r<BR>\r<BR>   БтКЮДТ ЧбЙј МіЧрЧЯИщ 8НУАЃГЛЗЮ ОШЕЫДЯДй.\r<BR>   ОЦИЖЕЕ ЧЯЗчПЁ ЕЮЙјСЄЕЕ АЁДЩЧЯИЎЖѓ Л§АЂЧЯДТЕЅ,\r<BR>   ЦђРЧШИ РкЛъРЛ П­НЩШї И№ОЦМ­ ОѓИЅ ДйРН ЧСЗЮСЇЦЎЕЕ\r<BR>   СјЧрЧеДЯДй.\r<BR>\r<BR>РЬЛѓРИЗЮ ИжЙЬСІБЙ ЦђРЧШИ РЧРх redbeeРЧ ПЌМГРЛ ИЖФЁАкНРДЯДй.\r<BR>ДйРНКЮХЭДТ АдНУЦЧПЁМ­ КЫЕЕЗЯ ЧЯСв.\r<BR>\r<BR>ЕЁ&gt; РЬЗИАд П­НЩШї РЯЧЯАэ РжДТ РЧРхПЁАд\r<BR>    ЦђРЧШИ ХѕЧЅПЁМ­ СіСіИІ ЦХЦХ ГЏЗССжНУИщ\r<BR>    ФПДйЖѕ РРПјРЬ ЕЧАкНРДЯДй ^^;\r<BR>\r<BR>    СЄБЧРќКЙРЛ ГыИЎАэ РжДТ ЦњДдРК СіСіРк И№С§РЛ\r<BR>    РкСІЧиСжНУБц ^^;\r<BR>   ','2002-04-04 10:52','218.50.131.97','redbee');
