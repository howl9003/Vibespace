--
-- Table structure for table 'fleet'
--

CREATE TABLE fleet (
  owner int(10) unsigned NOT NULL default '0',
  id int(10) unsigned NOT NULL default '0',
  name char(40) NOT NULL default '',
  admiral bigint(10) unsigned NOT NULL default '0',
  exp int(10) unsigned NOT NULL default '0',
  status int(10) unsigned NOT NULL default '0',
  maxship int(10) unsigned NOT NULL default '0',
  currentship int(10) unsigned NOT NULL default '0',
  shipclass int(10) unsigned NOT NULL default '0',
  mission int(10) unsigned NOT NULL default '0',
  mission_target int(10) unsigned NOT NULL default '0',
  mission_terminate_time int(10) unsigned NOT NULL default '0',
  killed_ship int(10) unsigned NOT NULL default '0',
  killed_fleet int(10) unsigned NOT NULL default '0',
  PRIMARY KEY  (owner,id)
) TYPE=MyISAM;

