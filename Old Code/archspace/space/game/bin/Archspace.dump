--
-- Table structure for table 'plan'
--

CREATE TABLE plan (
  owner int(10) unsigned NOT NULL default '0',
  id int(10) unsigned NOT NULL default '0',
  type tinyint(3) unsigned NOT NULL default '0',
  name char(40) NOT NULL default '',
  capital int(10) unsigned NOT NULL default '0',
  enemy int(10) unsigned NOT NULL default '0',
  min int(10) unsigned NOT NULL default '0',
  max int(10) unsigned NOT NULL default '0',
  attack_type int(10) unsigned NOT NULL default '0',
  PRIMARY KEY  (owner,id)
) TYPE=MyISAM;

--
-- Dumping data for table 'plan'
--


--
-- Table structure for table 'planet'
--

CREATE TABLE planet (
  id int(8) unsigned NOT NULL default '0',
  cluster int(8) unsigned NOT NULL default '0',
  owner int(8) unsigned NOT NULL default '0',
  order_ int(8) unsigned NOT NULL default '0',
  name char(50) NOT NULL default '',
  attribute char(8) default '',
  population int(10) unsigned NOT NULL default '0',
  building_factory smallint(5) unsigned NOT NULL default '0',
  building_military_base smallint(5) unsigned NOT NULL default '0',
  building_research_lab smallint(5) unsigned NOT NULL default '0',
  progress_factory smallint(5) unsigned NOT NULL default '0',
  progress_military_base smallint(5) unsigned NOT NULL default '0',
  progress_research_lab smallint(5) unsigned NOT NULL default '0',
  ratio_factory smallint(5) unsigned NOT NULL default '40',
  ratio_military_base smallint(5) unsigned NOT NULL default '30',
  ratio_research_lab smallint(5) unsigned NOT NULL default '30',
  atmosphere char(8) NOT NULL default '',
  temperature smallint(3) unsigned NOT NULL default '300',
  size tinyint(1) unsigned NOT NULL default '2',
  resource tinyint(1) unsigned NOT NULL default '2',
  gravity double unsigned NOT NULL default '1',
  investment int(10) unsigned NOT NULL default '0',
  terraforming smallint(1) unsigned NOT NULL default '0',
  terraforming_timer int(10) unsigned NOT NULL default '0',
  commerce_with_1 int(10) unsigned NOT NULL default '0',
  commerce_with_2 int(10) unsigned NOT NULL default '0',
  commerce_with_3 int(10) unsigned NOT NULL default '0',
  privateer_timer int(10) unsigned NOT NULL default '0',
  blockade_timer int(10) unsigned NOT NULL default '0',
  news_population int(10) unsigned NOT NULL default '0',
  news_factory smallint(5) unsigned NOT NULL default '0',
  news_military_base smallint(5) unsigned NOT NULL default '0',
  news_research_lab smallint(5) unsigned NOT NULL default '0',
  PRIMARY KEY  (id),
  KEY idx0 (owner)
) TYPE=MyISAM;

