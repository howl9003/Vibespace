--
-- Table structure for table 'empire_planet_info'
--

CREATE TABLE empire_planet_info (
  planet_id int(10) unsigned NOT NULL default '0',
  owner_id int(10) unsigned NOT NULL default '0',
  planet_type int(10) unsigned NOT NULL default '0',
  position_arg int(11) NOT NULL default '0',
  PRIMARY KEY  (planet_id)
) TYPE=MyISAM;

