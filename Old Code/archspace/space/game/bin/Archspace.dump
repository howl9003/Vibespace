CREATE TABLE fortress (
  layer int(10) unsigned NOT NULL default '0',
  sector int(10) unsigned NOT NULL default '0',
  fortress_order int(10) unsigned NOT NULL default '0',
  owner int(10) unsigned NOT NULL default '0',
  PRIMARY KEY  (layer,sector,fortress_order)
) TYPE=MyISAM;

