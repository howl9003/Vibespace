--
-- Table structure for table 'admission'
--

CREATE TABLE admission (
  player int(10) unsigned NOT NULL default '0',
  council int(10) unsigned NOT NULL default '0',
  status smallint(5) unsigned NOT NULL default '0',
  time int(10) unsigned NOT NULL default '0',
  content text,
  PRIMARY KEY  (player,council)
) TYPE=MyISAM;

--
-- Dumping data for table 'admission'
--


--
-- Table structure for table 'battle_record'
--

CREATE TABLE battle_record (
  id int(10) unsigned NOT NULL default '0',
  attacker_id int(10) unsigned NOT NULL default '0',
  defender_id int(10) unsigned NOT NULL default '0',
  attacker_name varchar(30) NOT NULL default '',
  defender_name varchar(30) NOT NULL default '',
  attacker_race int(10) unsigned NOT NULL default '0',
  defender_race int(10) unsigned NOT NULL default '0',
  attacker_council int(10) unsigned NOT NULL default '0',
  defender_council int(10) unsigned NOT NULL default '0',
  time int(10) unsigned NOT NULL default '0',
  war_type int(10) unsigned NOT NULL default '0',
  is_draw char(3) NOT NULL default 'NO',
  winner int(10) unsigned NOT NULL default '0',
  planet_id int(10) unsigned NOT NULL default '0',
  battle_field_name varchar(50) NOT NULL default '',
  attacker_gain text,
  attacker_lose_fleet text,
  attacker_lose_admiral text,
  defender_lose_fleet text,
  defender_lose_admiral text,
  record_file varchar(50) NOT NULL default '',
  there_was_battle tinyint(4) NOT NULL default '0',
  PRIMARY KEY  (id)
) TYPE=MyISAM;

--
-- Dumping data for table 'battle_record'
--

