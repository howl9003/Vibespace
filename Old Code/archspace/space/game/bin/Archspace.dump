--
-- Table structure for table 'player'
--

CREATE TABLE player (
  game_id int(10) unsigned NOT NULL default '0',
  portal_id int(10) unsigned NOT NULL default '0',
  name varchar(30) NOT NULL default '',
  home_cluster_id int(10) unsigned NOT NULL default '0',
  last_login int(10) unsigned NOT NULL default '0',
  last_login_ip varchar(15) NOT NULL default '000.000.000.000',
  mode tinyint(1) unsigned NOT NULL default '0',
  race tinyint(2) unsigned NOT NULL default '0',
  honor int(3) unsigned NOT NULL default '50',
  research_invest int(10) unsigned NOT NULL default '0',
  tick int(10) unsigned NOT NULL default '0',
  turn int(10) unsigned NOT NULL default '0',
  production int(10) unsigned NOT NULL default '0',
  ship_production int(10) unsigned NOT NULL default '0',
  invested_ship_production int(10) unsigned NOT NULL default '0',
  research int(10) unsigned NOT NULL default '0',
  ability varchar(65) default '',
  research_tech int(10) unsigned NOT NULL default '0',
  admiral_timer int(10) unsigned NOT NULL default '0',
  last_turn_production int(10) unsigned NOT NULL default '0',
  last_turn_research int(10) unsigned NOT NULL default '0',
  last_turn_military int(10) unsigned NOT NULL default '0',
  council_id smallint(6) unsigned NOT NULL default '0',
  council_vote smallint(6) unsigned NOT NULL default '0',
  council_production int(10) unsigned NOT NULL default '0',
  council_donation int(10) unsigned NOT NULL default '0',
  security_level tinyint(5) unsigned NOT NULL default '1',
  alertness int(11) unsigned NOT NULL default '0',
  empire_relation int(6) unsigned NOT NULL default '50',
  protected_mode tinyint(1) unsigned NOT NULL default '0',
  protected_terminate_time int(10) unsigned NOT NULL default '0',
  news_turn int(10) unsigned NOT NULL default '0',
  news_production int(10) unsigned NOT NULL default '0',
  news_research int(10) unsigned NOT NULL default '0',
  news_population int(10) unsigned NOT NULL default '0',
  news_ability varchar(65) default '',
  news_tech text,
  news_planet text,
  news_project text,
  news_admiral text,
  news_time_news longtext,
  PRIMARY KEY  (game_id),
  UNIQUE KEY idx1 (portal_id),
  KEY idx0 (name)
) TYPE=MyISAM;

