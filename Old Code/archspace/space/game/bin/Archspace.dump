CREATE TABLE admiral (
  id bigint(10) unsigned NOT NULL default '0',
  owner int(10) NOT NULL default '-1',
  race smallint(3) unsigned NOT NULL default '0',
  type smallint(3) unsigned NOT NULL default '0',
  name char(40) NOT NULL default '',
  exp int(10) unsigned NOT NULL default '0',
  level smallint(3) unsigned NOT NULL default '0',
  fleet_number int(10) unsigned NOT NULL default '0',
  armada_commanding tinyint(3) unsigned NOT NULL default '0',
  fleet_commanding smallint(3) NOT NULL default '-10',
  efficiency smallint(3) NOT NULL default '-10',
  siege_planet smallint(3) NOT NULL default '-10',
  siege_planet_up_level smallint(3) NOT NULL default '-10',
  blockade smallint(3) NOT NULL default '-10',
  blockade_up_level smallint(3) NOT NULL default '-10',
  raid smallint(3) NOT NULL default '-10',
  raid_up_level smallint(3) NOT NULL default '-10',
  privateer smallint(3) NOT NULL default '-10',
  privateer_up_level smallint(3) NOT NULL default '-10',
  siege_repelling smallint(3) NOT NULL default '-10',
  siege_repelling_up_level smallint(3) NOT NULL default '-10',
  break_blockade smallint(3) NOT NULL default '-10',
  break_blockade_up_level smallint(3) NOT NULL default '-10',
  prevent_raid smallint(3) NOT NULL default '-10',
  prevent_raid_up_level smallint(3) NOT NULL default '-10',
  maneuver smallint(3) NOT NULL default '-10',
  maneuver_up_level smallint(3) NOT NULL default '-10',
  detection smallint(3) NOT NULL default '-10',
  detection_up_level smallint(3) NOT NULL default '-10',
  interpretation smallint(3) NOT NULL default '-10',
  interpretation_up_level smallint(3) NOT NULL default '-10',
  commonability smallint(2) unsigned NOT NULL default '0',
  raceability smallint(2) unsigned NOT NULL default '0',
  PRIMARY KEY  (id)
) TYPE=MyISAM;

