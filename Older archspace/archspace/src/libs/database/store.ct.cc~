CStoreCenter::CStoreCenter()
{
	lock = false;
}

CStoreCenter::~CStoreCenter()
{
	mDeleteList.clear();
	mInsertUpdateList.clear();

	// TODO: remove -- called by MySQL~()
	if (mDatabaseConnection) mDatabaseConnection->close();
}

bool
CStoreCenter::initialize(CMySQL *aMySQL)
{
	if (!aMySQL)
	{
		system_log("NULL MySQL Connection in CStoreCenter::initialize()"); 
		return false; 
	}    
	mDatabaseConnection = aMySQL;
	return true;
}    
   
bool CStoreCenter::query (const char *aTable, const char *aQuery)
{
        int j;
       for (j=0; mDatabaseConnection->query(aQuery) && j < 3; j++)
       {
           system_log("retrying failed query!");
       }
       if (j != 3)
       {
          return true;
       }    
       else
       {
           system_log("failed: %s", aQuery);
       }    
       return false;
}
    
bool
CStoreCenter::store(CStore &aStore)
{
	if (aStore.get_type() == QUERY_DELETE)
	{
		mDeleteList.push_back((char*)aStore.query());
		map<unsigned int, CStore*>::iterator current = mInsertUpdateList.find(&aStore);
		if (current != mInsertUpdateList.end()) mInsertUpdateList.erase(current);
	}
	else
	{
		mInsertUpdateList[(unsigned int)&aStore] = &aStore;
	}
/*
	aStore.type(QUERY_NONE);
*/
	return true;
}

int
CStoreCenter::write()
{
	lock = true;
	static int count = 0;
	static int failed = 0;
	static time_t start = time(0);
	int j;
	//inserts & updates first
	map<unsigned int, CStore*>::iterator current;
	for (current = mInsertUpdateList.begin(); current != mInsertUpdateList.end(); current++)
	{
		for (j=0; mDatabaseConnection->query(current->second->query()) && j < 3; j++)
		{
			system_log("retrying failed query #%d!", j+1);
		}
		current->second->type(QUERY_NONE); 
		if (j != 3)
		{
			count++;
		}    
		else
		{
			failed++;
			lock = false;
			return 1;
		}
	}
	mInsertUpdateList.clear();
	
	//now for deletions
	while (mDeleteList.size() > 0)
	{
		for (j=0; mDatabaseConnection->query((char*)mDeleteList.front()) && j < 3; j++)
		{
			system_log("retrying failed query #%d!", j+1);
		}
		if (j != 3)
		{
			count++;
		}    
		else
		{
			failed++;
			lock = false;
			return 1;
		}
		mDeleteList.pop_front();
	}
	
	if (count == 0) 
	{
		lock = false;
		return -1;
	}
	
	if (time(0)-start >= 60)
	{
		system_log("DATABASE REPORT : TOTALS good queries = %d failed queries = %d, time period = %d, length = %d ", count, failed, time(0)-start, count+failed);
		start = time(0);
		count = 0;
		failed = 0;
	}
	lock = false;
	return 0;
